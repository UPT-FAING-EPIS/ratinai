else DNI válido
    C -> E : Patient::findByDni($dni)
    E -> BD : SELECT history_code\nFROM patients\nWHERE dni = ? LIMIT 1
    BD --> E : row / null
    E --> C : $patient / null

    alt Paciente no encontrado
        C --> V : return ['error' =>\n  'paciente_no_encontrado']
        V --> MED : HTTP 404 — "No se encontró ningún\npaciente con ese DNI.\nVerifique el número o\nregistre al paciente\nen un nuevo análisis"
    else Paciente encontrado
        C --> V : return [\n  'history_code' =>\n  $patient['history_code']\n]
        V --> MED : HTTP 200 — "El código de historial\nde este paciente es:\n[CÓDIGO]"
        MED -> V : Anota el código\nde historial
    end
end

