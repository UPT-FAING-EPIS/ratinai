' ============================================================
' RF-01: Crear Cuenta de Oftalmólogo
' ============================================================
@startuml RF01_Diseno_CrearCuentaOftalmologo
title RF-01: Crear Cuenta de Oftalmólogo [Diseño]

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ArrowColor #000000
skinparam SequenceLifeLineBorderColor #888888

actor "Administrador" as ADM

boundary "views/admin/\ncreate_doctor.php" as V
control "controllers/\nDoctorController.php\n::createDoctor()" as C
control "services/\nMailService.php\n::sendTempPassword()" as MS
entity "models/\nDoctorModel.php" as E
database "Railway DB\n(tablas: usuarios, maestro)" as BD

== POST controllers/DoctorController.php?action=create ==

ADM -> V : Envía formulario\nPOST: nombre, correo, cmp,\nespecialidad, esp_nueva, password_temp
V -> C : HTTP POST a DoctorController::createDoctor()

C -> C : Extrae y limpia campos.\nValida obligatorios y formato email.\nValida longitud de password_temp (>= 6)

alt Campos vacíos o inválidos
    C -> C : $_SESSION['flash_errors'] = [...]
    C --> V : HTTP 302 Redirect a\nviews/admin/create_doctor.php
    V --> ADM : Muestra alertas de error\ncon $_SESSION['flash_errors']
else Datos válidos
    C -> E : DoctorModel::existsByEmail($correo)\nDoctorModel::existsByCMP($cmp)
    E -> BD : SELECT id FROM usuarios\nWHERE correo=? / cmp=? LIMIT 1
    BD --> E : row / false
    E --> C : true / false

    alt Correo o CMP ya registrado
        C -> C : $_SESSION['flash_errors'] = [...]
        C --> V : HTTP 302 Redirect a\nviews/admin/create_doctor.php
        V --> ADM : Muestra alertas de duplicidad
    else Disponibles
        alt especialidad == '__nueva__'
            C -> E : DoctorModel::addSpecialty($esp_nueva)
            E -> BD : INSERT INTO maestro (tipo, codigo,\ndescripcion, orden) VALUES (...)
        end
        
        C -> C : $hash = password_hash(\n  $password_temp, PASSWORD_BCRYPT\n)
        C -> E : DoctorModel::create([\n  'nombre' => $nombre,\n  'email' => $correo,\n  'cmp' => $cmp,\n  'especialidad' => $especialidad_final,\n  'password' => $hash,\n  'establecimiento_id' => $est_id\n])
        E -> BD : INSERT INTO usuarios (nombre, correo,\npassword, rol_codigo, cmp, especialidad,\nestablecimiento_id, activo, es_password_temporal)\nVALUES (?, ?, ?, 'MED', ?, ?, ?, 1, 1)
        BD --> E : INSERT OK — lastInsertId()
        E --> C : $lastInsertId

        C -> MS : MailService::sendTempPassword(\n  $correo, $nombre, $password_temp\n)

        alt SMTP responde 250 OK
            MS --> C : return true
            C -> C : $_SESSION['flash_success'] = \n"Cuenta creada. Contraseña enviada..."
            C --> V : HTTP 302 Redirect a\nviews/admin/doctor.php
            V --> ADM : Muestra tabla con el nuevo\nmédico y alerta verde de éxito
        else SMTP falla / sin configurar
            MS --> C : return false
            C -> C : $_SESSION['flash_success'] = "Creado exitosamente..."\n$_SESSION['flash_temp_pass'] = $password_temp
            C --> V : HTTP 302 Redirect a\nviews/admin/create_doctor.php
            V --> ADM : Muestra alerta de éxito y\ncuadro azul con la contraseña\ntemporal para entrega manual
        end
    end
end

@enduml


' ============================================================
' RF-02: Iniciar Sesión
' ============================================================
@startuml RF02_Diseno_IniciarSesion
title RF-02: Iniciar Sesión [Diseño]

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ArrowColor #000000
skinparam SequenceLifeLineBorderColor #888888

actor "Usuario\n(Médico / Admin / SuperAdmin)" as USR

boundary "views/auth/\nlogin.php" as V_LOGIN
boundary "views/auth/\nchange_password.php" as V_CP
control "controllers/\nAuthController.php\n::login()" as C
control "controllers/\nAuthController.php\n::changePassword()" as C_CP
entity "models/\nAuthModel.php" as E
database "Railway DB\n(tabla: usuarios)" as BD

== GET views/auth/login.php ==

USR -> V_LOGIN : HTTP GET views/auth/login.php
V_LOGIN --> USR : HTTP 200 — Formulario:\n<form method="POST"\n  action="...AuthController.php?action=login">\n  <input name="email">\n  <input name="password" type="password">\n  (muestra $_SESSION['login_error'] si existe)

== POST controllers/AuthController.php?action=login ==

USR -> V_LOGIN : Submit formulario\nPOST: email, password
V_LOGIN -> C : HTTP POST AuthController.php?action=login

C -> C : $email = trim($_POST['email'] ?? '')\n$password = $_POST['password'] ?? ''\nif (empty($email) || empty($password)):

alt Campos vacíos
    C -> C : $_SESSION['login_error'] =\n  "Por favor ingrese correo y contraseña."
    C --> V_LOGIN : HTTP 302 Redirect\n→ views/auth/login.php
    V_LOGIN --> USR : Muestra alerta de error
else Campos presentes
    C -> E : AuthModel::getUserByEmail($email)
    E -> BD : SELECT * FROM usuarios\nWHERE correo = :correo\nAND activo = 1 LIMIT 1
    BD --> E : row / false
    E --> C : $user[] / false

    alt Usuario no encontrado (false)
        C -> C : $_SESSION['login_error'] =\n  "Credenciales incorrectas. Verifique\n  su correo y contraseña."
        C --> V_LOGIN : HTTP 302 Redirect\n→ views/auth/login.php
        V_LOGIN --> USR : Muestra alerta de error genérico
    else Usuario encontrado
        C -> C : password_verify($password, $user['password'])

        alt Hash no coincide
            C -> C : $_SESSION['login_error'] =\n  "Credenciales incorrectas..."
            C --> V_LOGIN : HTTP 302 Redirect\n→ views/auth/login.php
            V_LOGIN --> USR : Muestra alerta de error genérico
        else Hash coincide
            C -> C : Verifica $user['activo'] == 1

            alt activo == 0
                C -> C : $_SESSION['login_error'] =\n  "Su cuenta aún no ha sido aprobada\n  por el administrador."
                C --> V_LOGIN : HTTP 302 Redirect\n→ views/auth/login.php
                V_LOGIN --> USR : Muestra alerta cuenta inactiva
            else activo == 1 — Sesión exitosa
                C -> E : AuthModel::updateLastAccess($user['id'])
                E -> BD : UPDATE usuarios\nSET ultimo_acceso = NOW()\nWHERE id = :id
                BD --> E : OK

                C -> C : $_SESSION['user_id'] = $user['id']\n$_SESSION['rol_codigo'] = $user['rol_codigo']\n$_SESSION['nombre'] = $user['nombre']\n$_SESSION['establecimiento_id'] = $user['establecimiento_id']\n$_SESSION['es_password_temporal'] = (bool)$user['es_password_temporal']\n$_SESSION['last_activity'] = time()

                alt $user['es_password_temporal'] == true
                    C --> V_LOGIN : HTTP 302 Redirect\n→ views/auth/change_password.php
                    V_LOGIN --> USR : Redirige a pantalla de\ncambio de contraseña obligatorio

                    == POST controllers/AuthController.php?action=change_password ==

                    USR -> V_CP : Ingresa nueva contraseña\ny confirmación
                    V_CP -> C_CP : HTTP POST AuthController.php?action=change_password
                    C_CP -> C_CP : $nueva = $_POST['nueva_password']\n$confirma = $_POST['confirma_password']\nif (strlen($nueva) < 6):

                    alt Contraseña < 6 chars
                        C_CP -> C_CP : $_SESSION['cp_error'] =\n  "La contraseña debe tener al menos 6 caracteres."
                        C_CP --> V_CP : HTTP 302 Redirect\n→ views/auth/change_password.php
                        V_CP --> USR : Muestra mensaje de error
                    else Contraseñas no coinciden
                        C_CP -> C_CP : if ($nueva !== $confirma):\n  $_SESSION['cp_error'] =\n  "Las contraseñas no coinciden."
                        C_CP --> V_CP : HTTP 302 Redirect
                        V_CP --> USR : Muestra mensaje de error
                    else Contraseña válida
                        C_CP -> C_CP : $hash = password_hash($nueva, PASSWORD_BCRYPT)
                        C_CP -> E : AuthModel::updatePassword(\n  $_SESSION['user_id'], $hash)
                        E -> BD : UPDATE usuarios\nSET password = :password,\nes_password_temporal = 0\nWHERE id = :id
                        BD --> E : UPDATE OK
                        C_CP -> C_CP : $_SESSION['es_password_temporal'] = false\nredirectByRole($_SESSION['rol_codigo'])
                        C_CP --> V_CP : HTTP 302 Redirect según rol
                        V_CP --> USR : Accede al panel correspondiente
                    end

                else $user['es_password_temporal'] == false
                    C -> C : redirectByRole($user['rol_codigo']):\n  'SAD' → views/superadmin/index.php\n  'ADM' → views/admin/index.php\n  'MED' → views/medico/index.php
                    C --> V_LOGIN : HTTP 302 Redirect según rol
                    V_LOGIN --> USR : Accede al panel correspondiente
                end
            end
        end
    end
end

@enduml


' ============================================================
' RF-03: Gestionar Médicos Activos del Establecimiento
' ============================================================
@startuml RF03_Diseno_GestionarMedicos_Actualizado
title RF-03: Gestionar Médicos Activos del Establecimiento [Diseño Actualizado]

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ArrowColor #000000
skinparam SequenceLifeLineBorderColor #888888

actor "Administrador\n(Frontend)" as ADM

boundary "views/admin/\ndoctor.php" as V
boundary "Pop-up DOM\n#modal-edit" as MEdit
boundary "Pop-up DOM\n#modal-reset" as MReset
control "controllers/\nDoctorController.php\n::editDoctor()\n::resetPassword()\n::deactivate()" as C
control "utils/\nPasswordHelper.php\n::generateTemp()" as PH
control "services/\nMailService.php\n::sendResetPassword()" as MS
entity "models/\nDoctorModel.php" as E
database "Railway DB\n(tabla: usuarios)" as BD

== GET views/admin/doctor.php ==

ADM -> V : HTTP GET /admin/doctor.php
V -> E : DoctorModel::getActiveDoctorsByEstablishments($est_ids[])
E -> BD : SELECT u.id, u.nombre, u.correo, u.cmp,\nu.especialidad, u.ultimo_acceso,\nu.es_password_temporal, u.establecimiento_id,\ne.nombre AS est_nombre\nFROM usuarios u\nLEFT JOIN establecimientos e ON e.id=u.establecimiento_id\nWHERE u.rol_codigo='MED' AND u.activo=1\nAND u.establecimiento_id IN (?) ORDER BY e.nombre, u.nombre
BD --> E : rows[] (PDO::FETCH_ASSOC)
E --> V : array $activos
V --> ADM : HTTP 200 OK HTML\nRenderiza <table id="doctorsTable">\nModales #modal-edit y #modal-reset\nembebidos en el mismo doctor.php

== POST controllers/DoctorController.php?action=edit ==

ADM -> V : Clic "Editar" en la tabla
V -> MEdit : Despliega modal de edición
ADM -> MEdit : Ingresa nuevos datos y hace submmit
MEdit -> C : fetch('?action=edit') via FormData\n{edit_id: int, nombre: string, correo: string,\n cmp: string, especialidad: string}
C -> E : DoctorModel::existsByEmail($correo, $edit_id)
E -> BD : SELECT id FROM usuarios\nWHERE correo=? AND id!=? LIMIT 1
BD --> E : row / false
E --> C : boolean

alt existsByEmail == true

    C --> MEdit : HTTP 200 Content-Type: application/json\n{"success": false, "message": "El correo ya está en uso por otro médico."}
    MEdit --> ADM : JavaScript muestra toastify/alerta de error

else existsByEmail == false

    C -> E : DoctorModel::existsByCMP($cmp, $edit_id)
    E -> BD : SELECT id FROM usuarios WHERE cmp=?\nAND rol_codigo='MED' AND id!=?\nLIMIT 1
    BD --> E : row / false
    E --> C : boolean

    alt existsByCMP == true

        C --> MEdit : HTTP 200 Content-Type: application/json\n{"success": false, "message": "El CMP ya está en uso por otro médico."}
        MEdit --> ADM : JavaScript muestra toastify/alerta de error

    else existsByCMP == false

        C -> E : DoctorModel::updateDoctor($edit_id, $est_id, $data)
        E -> BD : UPDATE usuarios SET nombre=?, correo=?,\ncmp=?, especialidad=? WHERE id=?\nAND establecimiento_id=? AND rol_codigo='MED'
        BD --> E : PDOStatement::execute() OK
        E --> C : boolean true

        C --> MEdit : HTTP 200 Content-Type: application/json\n{"success": true}
        MEdit -> V : Cierra modal y dispara\nwindow.location.reload()
        V --> ADM : Toastify "Médico actualizado exitosamente"

    end
end

== POST controllers/DoctorController.php?action=reset ==

ADM -> V : Clic "Resetear contraseña" en la tabla
V -> MReset : Despliega modal de confirmación
ADM -> MReset : Clic "Confirmar"
MReset -> C : fetch('?action=reset') via FormData\n{reset_id: int}
C -> E : DoctorModel::findById($reset_id, $est_id)
E -> BD : SELECT * FROM usuarios WHERE id=? AND establecimiento_id=?
BD --> E : row(doctor)
E --> C : array $doctor (contiene email, nombre)

C -> PH : PasswordHelper::generateTemp(8)
PH --> C : string $tempPass (ej. A1B2c3D4)

C -> C : $hash = password_hash($tempPass, PASSWORD_BCRYPT)

C -> E : DoctorModel::resetPassword($reset_id, $est_id, $hash)
E -> BD : UPDATE usuarios SET password=?, es_password_temporal=1\nWHERE id=? AND establecimiento_id=?
BD --> E : PDOStatement::execute() OK
E --> C : boolean true

C -> MS : MailService::sendResetPassword($doctor['correo'], $doctor['nombre'], $tempPass)
MS -> MS : PHPMailer::send() a SMTP
MS --> C : boolean

alt Mailer successfully sent

    C --> MReset : HTTP 200 Content-Type: application/json\n{"success": true}
    MReset -> V : Cierra modal y dispara\nwindow.location.reload()
    V --> ADM : Tabla recargada con Toastify de éxito

else Mailer threw Exception

    C --> MReset : HTTP 200 Content-Type: application/json\n{"success": false, "message": "No se pudo enviar el correo de recuperación..."}
    MReset --> ADM : JavaScript muestra toastify de error

end

== POST controllers/DoctorController.php?action=deactivate ==

ADM -> V : Form submit nativo <form method="POST">
V -> C : HTTP POST payload: {target_id: int}
C -> E : DoctorModel::deactivate($target_id, $est_id)
E -> BD : UPDATE usuarios SET activo=0 WHERE id=?\nAND establecimiento_id=? AND rol_codigo='MED'
BD --> E : PDOStatement::execute() OK
E --> C : boolean true

C -> C : $_SESSION['flash_success'] = "médico desactivado"
C --> V : HTTP 302 Redirect Location: doctor.php
V --> ADM : Renderiza tabla sin médico desactivado

@enduml

' ============================================================
' RF-04: Habilitar Establecimiento
' ============================================================
@startuml RF04_Diseno_HabilitarEstablecimiento
title RF-04: Habilitar Establecimiento [Diseño]

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ArrowColor #000000
skinparam SequenceLifeLineBorderColor #888888

actor "Super Administrador" as SADM

boundary "views/superadmin/\ncreate_establishment.php" as V
control "controllers/\nEstablishmentController.php\n::create()" as C
control "services/\nMailService.php\n::sendTempPassword()" as MS
entity "models/\nEstablishment.php" as EE
entity "models/\nAdmin.php" as EA
database "Railway DB\n(tablas: establishments,\nadmins)" as BD

== POST /superadmin/establishments/create ==

SADM -> V : Envía formulario\nPOST: nombre, direccion, tipo,\nadmin_nombre, admin_email
V -> C : EstablishmentController::create(\n  $nombre, $direccion, $tipo,\n  $adminNombre, $adminEmail\n)

C -> C : Validator::required([\n  'nombre','direccion','tipo',\n  'adminNombre','adminEmail'\n])\nValidator::email($adminEmail)

alt Datos incompletos o inválidos
    C --> V : return ['error' =>\n  'Campos inválidos', 'fields' => [...]]
    V --> SADM : HTTP 422 — Resalta campos\ncon error
else Datos válidos
    C -> EE : Establishment::create([\n  'nombre'     => $nombre,\n  'direccion'  => $direccion,\n  'tipo'       => $tipo,\n  'estado'     => 'activo',\n  'created_at' => now()\n])
    EE -> BD : INSERT INTO establishments\n(nombre, direccion, tipo,\nestado, created_at)\nVALUES (?, ?, ?, 'activo', NOW())
    BD --> EE : INSERT OK — lastInsertId()
    EE --> C : $establishmentId

    C -> C : $tempPass =\n  PasswordHelper::generateTemp(12)\n$hash =\n  password_hash($tempPass,\n  PASSWORD_BCRYPT)
    C -> EA : Admin::create([\n  'nombre'           => $adminNombre,\n  'email'            => $adminEmail,\n  'password'         => $hash,\n  'is_temp_pass'     => true,\n  'rol'              => 'administrador',\n  'estado'           => 'activo',\n  'establishment_id' => $establishmentId,\n  'created_at'       => now()\n])
    EA -> BD : INSERT INTO admins\n(nombre, email, password,\nis_temp_pass, rol, estado,\nestablishment_id, created_at)\nVALUES (?, ?, ?, 1,\n'administrador', 'activo', ?, NOW())
    BD --> EA : INSERT OK
    EA --> C : $adminId

    C -> MS : MailService::sendTempPassword(\n  $adminEmail, $adminNombre,\n  $tempPass\n)
    MS --> C : return true / false

    C --> V : return ['success' =>\n  'Establecimiento y administrador\n  creados correctamente']
    V --> SADM : HTTP 201 — "Establecimiento registrado\ny Administrador asignado\ncorrectamente"
end

@enduml

' ============================================================
' RF-07: Recuperar Código de Historial por DNI
' ============================================================
@startuml RF07_Diseno_RecuperarCodigoHistorial
title RF-07: Recuperar Código de Historial por DNI [Diseño]

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ArrowColor #000000
skinparam SequenceLifeLineBorderColor #888888

actor "Médico Oftalmólogo" as MED

boundary "views/analysis/\nrecover_history.php" as V
control "controllers/\nPatientController.php\n::recoverHistoryCode()" as C
entity "models/\nPatient.php" as E
database "Railway DB\n(tabla: patients)" as BD

== GET /patients/recover-code ==

MED -> V : Accede a\n"Recuperar código de historial"\ndesde el módulo de análisis
V --> MED : HTTP 200 — Muestra campo\npara ingresar DNI

== POST /patients/recover-code ==

MED -> V : Envía formulario\nPOST: dni
V -> C : PatientController::recoverHistoryCode(\n  $dni\n)

C -> C : Validator::regex(\n  $dni, '/^\d{8}$/'\n)

alt DNI con formato inválido
    C --> V : return ['error' =>\n  'dni_invalido']
    V --> MED : HTTP 422 — "Ingrese un DNI\nválido de 8 dígitos"
else DNI válido
    C -> E : Patient::findByDni($dni)
    E -> BD : SELECT history_code\nFROM patients\nWHERE dni = ? LIMIT 1
    BD --> E : row / null
    E --> C : $patient / null

    alt Paciente no encontrado
        C --> V : return ['error' =>\n  'paciente_no_encontrado']
        V --> MED : HTTP 404 — "No se encontró ningún\npaciente con ese DNI.\nVerifique el número o\nregistre al paciente\nen un nuevo análisis"
    else Paciente encontrado
        C --> V : return [\n  'history_code' =>\n  $patient['history_code']\n]
        V --> MED : HTTP 200 — "El código de historial\nde este paciente es:\n[CÓDIGO]"
        MED -> V : Anota el código\nde historial
    end
end

@enduml


' ============================================================
' RF-08: Solicitar Registro de Centro Oftalmológico
' ============================================================
@startuml RF08_Diseno_RegistroCentroOftalmologico
title RF-08: Solicitar Registro de Centro Oftalmológico y Aprobación [Diseño]

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ArrowColor #000000
skinparam SequenceLifeLineBorderColor #888888

actor "Titular del Centro\nOftalmológico" as DUENO
actor "Super Administrador" as SADM

boundary "index.php" as IDX
boundary "views/auth/\nsolicitud_registro.php" as V_REG
boundary "assets/js/auth/\nsolicitud_registro.js" as JS
boundary "views/superadmin/\nSolicitudesRegistro.php" as V_SAD
control "controllers/\nSolicitudController.php" as C
control "services/\nMailService.php" as MS
database "Railway DB" as BD

== GET index.php ==

DUENO -> IDX : Visita index.php
IDX --> DUENO : HTTP 200 — Landing con botones:\n[Ingresar a la Plataforma]\n[Registrar centro oftalmológico]

DUENO -> IDX : Clic <a href="views/auth/solicitud_registro.php"\nclass="btn btn-outline btn-lg">\n"Registrar centro oftalmológico"

== GET views/auth/solicitud_registro.php ==

IDX -> V_REG : HTTP GET views/auth/solicitud_registro.php
V_REG -> V_REG : session_start()\nlee $_SESSION['solicitud_success']\ny $_SESSION['solicitud_error'] — luego unset()
V_REG --> DUENO : HTTP 200 — Formulario:\n<form id="form-solicitud"\n  action="../../controllers/SolicitudController.php"\n  method="POST" enctype="multipart/form-data">\n  <input hidden name="action" value="solicitar">\n  <input hidden id="evidencia_1_b64">\n  <input hidden id="evidencia_1_nombre">\n  <input hidden id="evidencia_2_b64">\n  <input hidden id="evidencia_2_nombre">\n  Campos: nombre_centro, direccion,\n  tipo (radio publico|privado), ruc,\n  dni_titular, nombres_titular,\n  apellidos_titular, telefono,\n  correo_contacto + #btn-send-code\n  codigo_verificacion (hidden hasta enviar código)\n  #upload-area (drag&drop, JPG/PNG/PDF ≤200KB)
V_REG --> DUENO : Carga <script\n  src="../../assets/js/auth/solicitud_registro.js">

== Paso 1: Envío de código OTP (AJAX fetch) ==

DUENO -> JS : Completa correo_contacto y nombres_titular\nClic en button#btn-send-code "Enviar código"
JS -> JS : enviarCodigo():\n  correo = correo_contacto.value.trim()\n  nombres = nombres_titular.value.trim()\n  Valida regex /^[^\s@]+@[^\s@]+\.[^\s@]+$/\n  btn.disabled=true; btn.classList.add('loading')
JS -> C : fetch('../../controllers/SolicitudController.php\n  ?action=send_code', {\n  method:'POST',\n  headers:{'Content-Type':\n    'application/x-www-form-urlencoded'},\n  body: 'correo='+encodeURIComponent(correo)\n        +'&nombres='+encodeURIComponent(nombres) })
C -> C : $action = $_GET['action'] = 'send_code'\nhandleSendCode():\n  header('Content-Type: application/json')\n  $correo = trim($_POST['correo'])\n  $nombres = trim($_POST['nombres'] ?? 'Solicitante')\n  filter_var($correo, FILTER_VALIDATE_EMAIL)
C -> C : $codigo = sprintf("%06d", mt_rand(1, 999999))\n$_SESSION['verification_code'] = $codigo\n$_SESSION['verification_email'] = $correo\n$_SESSION['verification_time'] = time()
C -> MS : MailService::sendVerificationCode(\n  $correo, $nombres, $codigo)
MS -> MS : PHPMailer SMTP:\nSubject: "RetinAI — Código de verificación para registro"\nBody: código en span monospace 34px + timer "10 min"
MS --> C : return true / false

alt SMTP responde 250 OK
    C --> JS : echo json_encode(['success' => true])
    JS -> JS : codeSent = true\nmostrarCodigoEnviado(correo):\n  #code-sent-msg.classList.add('show')\n  #code-input-wrap.classList.add('show')\n  inicia setInterval resend 60s\n  inicia setInterval expire 600s → "10:00"
    JS --> DUENO : Muestra "Código enviado a {correo}."\n#codigo_verificacion visible con countdown
else SMTP falla
    C --> JS : json_encode(['success'=>false,\n  'message'=>'No se pudo enviar...'])
    JS --> DUENO : errEl.textContent = message\nbtn-send-code.disabled = false
end

== Paso 2: Selección de evidencias (FileReader API) ==

DUENO -> JS : Selecciona archivo(s) en #file-input\no arrastra sobre #upload-area (ondrop)
JS -> JS : agregarArchivos(files[]):\n  Valida ALLOWED_TYPES:\n  ['image/jpeg','image/png','application/pdf']\n  Valida file.size <= 200*1024 bytes\n  Valida uploadedFiles.length < 2
JS -> JS : leerComoBase64(file):\n  FileReader.readAsDataURL(file)\n  uploadedFiles.push({name,type,b64})\n  renderPreviews()\n  actualizarHiddenInputs():\n    #evidencia_1_b64.value = uploadedFiles[0]?.b64\n    #evidencia_1_nombre.value = uploadedFiles[0]?.name\n    #evidencia_2_b64.value = uploadedFiles[1]?.b64\n    #evidencia_2_nombre.value = uploadedFiles[1]?.name
JS --> DUENO : Renderiza .file-preview-item\n(img preview si image/*, icono 📄 si PDF)\nBotón ✕ onclick="removerArchivo(idx)"

== Paso 3: Submit del formulario ==

DUENO -> JS : Clic en button#submit-btn "Enviar solicitud"
JS -> JS : handleFormSubmit(e): e.preventDefault()\nValida nombre_centro (not empty)\nValida direccion (not empty)\nValida tipo = document.querySelector('input[name="tipo"]:checked')\nValida ruc: /^\d{11}$/\nValida dni: /^\d{8}$/\nValida nombres_titular, apellidos_titular (not empty)\nValida telefono: /^[\d\s\+\-\(\)]{7,15}$/\nValida correo regex\nValida codeSent === true\nValida codigo: /^\d{6}$/\nValida uploadedFiles.length >= 1

alt Validación client-side falla
    JS --> DUENO : fieldErr() → input.classList.add('error')\n#client-error-box.style.display='flex'\n"Por favor, complete todos los campos..."
else Validación OK
    JS -> JS : submitBtn.classList.add('loading')\nsubmitBtn.disabled = true
    JS -> C : document.getElementById('form-solicitud').submit()\nHTTP POST controllers/SolicitudController.php\n  action=solicitar\n  nombre_centro, direccion, tipo (publico|privado),\n  ruc, dni_titular, nombres_titular,\n  apellidos_titular, telefono,\n  correo_contacto, codigo_verificacion,\n  evidencia_1_b64 (data:...;base64,...),\n  evidencia_1_nombre, evidencia_2_b64?, evidencia_2_nombre?
end

C -> C : $action = $_POST['action'] = 'solicitar'\nhandleSolicitar():\n  $nombre_centro = trim($_POST['nombre_centro'])\n  $ruc = trim($_POST['ruc'])\n  $correo_contacto = trim($_POST['correo_contacto'])\n  $codigo_verificacion = trim($_POST['codigo_verificacion'])\n  $evidencia_1_b64 = $_POST['evidencia_1_b64'] ?? null\n  ... (todos los campos)

C -> C : Validaciones servidor:\n1) Todos los campos not empty\n2) $_SESSION['verification_code'] existe\n3) $_SESSION['verification_email'] == $correo_contacto\n4) time()-$_SESSION['verification_time'] <= 600\n5) $_SESSION['verification_code'] == $codigo_verificacion\n6) in_array($tipo,['publico','privado'])\n7) preg_match('/^\d{11}$/', $ruc)\n8) preg_match('/^\d{8}$/', $dni_titular)\n9) !empty($evidencia_1_b64)

alt Alguna validación de servidor falla
    C -> C : $_SESSION['solicitud_error'] = "mensaje"
    C --> V_REG : HTTP 302 Location: views/auth/solicitud_registro.php
    V_REG --> DUENO : Renderiza .alert-box.alert-danger con\nhtmlspecialchars($error_msg)
else Todas las validaciones OK
    C -> BD : (new Database())->getConnection()\nSELECT COUNT(*) FROM establecimientos\nWHERE ruc = ? → execute([$ruc])
    BD --> C : 0
    C -> BD : SELECT COUNT(*) FROM solicitudes_establecimiento\nWHERE ruc = ? AND estado IN ('pendiente','aprobado')
    BD --> C : 0

    alt RUC duplicado
        C -> C : $_SESSION['solicitud_error'] = "Ya existe..."
        C --> V_REG : HTTP 302 Redirect
        V_REG --> DUENO : Muestra error
    else RUC disponible
        C -> BD : $stmt->prepare(\n  "INSERT INTO solicitudes_establecimiento\n   (nombre_centro, direccion, tipo, ruc,\n    dni_titular, nombres_titular, apellidos_titular,\n    telefono, correo_contacto,\n    evidencia_1, evidencia_1_nombre,\n    evidencia_2, evidencia_2_nombre,\n    estado, fecha_solicitud)\n   VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,'pendiente',NOW())")\n  ->execute([...13 valores...])
        BD --> C : affected rows = 1
        C -> C : unset($_SESSION['verification_code'],\n  $_SESSION['verification_email'],\n  $_SESSION['verification_time'])
        C -> C : $_SESSION['solicitud_success'] =\n  "Su solicitud ha sido enviada correctamente.\n  El administrador revisará su información\n  y le notificará el resultado."
        C --> V_REG : HTTP 302 Location: views/auth/solicitud_registro.php
        V_REG --> DUENO : if($success_msg): renderiza .success-screen:\n  ✅ "¡Solicitud enviada!" + $success_msg\n  <a href="../../index.php">Volver al inicio</a>
    end
end

== Aprobación — Super Administrador ==

SADM -> V_SAD : HTTP GET views/superadmin/SolicitudesRegistro.php
V_SAD -> V_SAD : require_role('SAD'):\n  verifica $_SESSION['rol_codigo']==='SAD'\n$user = current_user()\nlee y unset $_SESSION['solicitud_msg']
V_SAD -> BD : SolicitudModel::getAllSolicitudesConOrigen()\nSELECT s.*, u.nombre AS nombre_usuario_solicitante\nFROM solicitudes_establecimiento s\nLEFT JOIN usuarios u ON u.id = s.id_usuario_solicitante\nORDER BY FIELD(s.estado,'pendiente','aprobado','rechazado'),\ns.fecha_solicitud DESC
BD --> V_SAD : $solicitudes[]
V_SAD -> BD : SolicitudModel::countPendientes()\nSELECT COUNT(*) FROM solicitudes_establecimiento\nWHERE estado='pendiente'
BD --> V_SAD : int $cnt
V_SAD --> SADM : HTTP 200 — <table.data-table>:\n  Columnas: Centro Oftalmológico, Titular,\n  Contacto (tel + email), Evidencias (btn-preview),\n  Fecha, Estado (badge-pending/approved/rejected),\n  Acciones [✓ Aprobar] [✗ Rechazar]\n  (solo si estado==='pendiente')\n  Carga: assets/js/dashboard/solicitudes.js\n  (modal preview base64 img/PDF)

SADM -> V_SAD : Clic button.btn-approve "✓ Aprobar"\nconfirm('¿Aprobar esta solicitud, crear el\n  establecimiento y enviar correo al titular?')
V_SAD -> C : <form method="POST"\n  action="{$base}controllers/SolicitudController.php">\nHTTP POST:\n  action=aprobar\n  id={$s['id']} (int)
C -> C : require_role('SAD')\n$action = $_POST['action'] = 'aprobar'\nhandleAprobar():\n  $id = (int)($_POST['id'] ?? 0)
C -> BD : SELECT * FROM solicitudes_establecimiento\nWHERE id = ? AND estado = 'pendiente'\n→ fetch(PDO::FETCH_ASSOC)
BD --> C : $sol[] con todos los campos

C -> BD : SELECT id FROM usuarios\nWHERE correo = ? AND rol_codigo = 'ADM'
BD --> C : $usuario_existente_id / false

alt ADM ya existe con ese correo
    C -> BD : INSERT INTO establecimientos\n  (nombre, direccion, tipo, ruc, id_usuario)\n  VALUES (?, ?, ?, ?, $usuario_existente_id)
    BD --> C : lastInsertId() → $establecimiento_id
    C -> BD : UPDATE solicitudes_establecimiento\n  SET estado = 'aprobado' WHERE id = ?
    C -> MS : MailService::sendSolicitudAprobada(\n  $sol['correo_contacto'],\n  $nombreCompleto, $sol['nombre_centro'])
    MS -> MS : PHPMailer SMTP:\nSubject: "RetinAI — ¡Su solicitud fue aprobada!"
    MS --> C : return bool
else ADM nuevo — crear cuenta y establecimiento
    C -> C : $tempPass = bin2hex(random_bytes(4))\n$hashPass = password_hash($tempPass, PASSWORD_DEFAULT)\n$nombreCompleto = trim($sol['nombres_titular']\n  . ' ' . $sol['apellidos_titular'])
    C -> BD : INSERT INTO usuarios\n  (rol_codigo, establecimiento_id, nombre,\n   correo, password, es_password_temporal, activo)\n  VALUES ('ADM', NULL, ?, ?, ?, 1, 1)
    BD --> C : lastInsertId() → $nuevo_usuario_id
    C -> BD : INSERT INTO establecimientos\n  (nombre, direccion, tipo, ruc, id_usuario)\n  VALUES (?, ?, ?, ?, $nuevo_usuario_id)
    BD --> C : lastInsertId() → $establecimiento_id
    C -> BD : UPDATE usuarios\n  SET establecimiento_id = ?\n  WHERE id = $nuevo_usuario_id
    C -> BD : UPDATE solicitudes_establecimiento\n  SET estado = 'aprobado' WHERE id = ?
    C -> MS : MailService::sendSolicitudAprobada(\n  $sol['correo_contacto'],\n  $nombreCompleto, $sol['nombre_centro'])
    MS -> MS : PHPMailer SMTP:\nSubject: "RetinAI — ¡Su solicitud fue aprobada!"
    MS --> C : return bool
    C -> MS : MailService::sendTempPassword(\n  $sol['correo_contacto'],\n  $nombreCompleto, $tempPass)
    MS -> MS : PHPMailer SMTP:\nSubject: "Acceso a RetinAI - Su cuenta ha sido creada"\nBody: contraseña $tempPass en caja monospace\n+ <a href="login.php">Iniciar Sesión Ahora</a>
    MS --> C : return bool
end

C -> C : $_SESSION['solicitud_msg'] =\n  "Solicitud aprobada. El centro\n  «{$sol['nombre_centro']}» ha sido registrado\n  y se enviaron las credenciales al titular."
C --> V_SAD : HTTP 302 Location:\n  views/superadmin/SolicitudesRegistro.php
V_SAD --> SADM : if($solicitud_msg): renderiza .alert-flash\n(background:#D1FAE5, border:#6EE7B7):\n  "Solicitud aprobada. El centro «...»..."

@enduml

