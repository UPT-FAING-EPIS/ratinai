' ============================================================
' RF-01: Crear Cuenta de Oftalmólogo
' ============================================================
@startuml RF01_Diseno_CrearCuentaOftalmologo
title RF-01: Crear Cuenta de Oftalmólogo [Diseño]

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ArrowColor #000000
skinparam SequenceLifeLineBorderColor #888888

actor "Administrador" as ADM

boundary "views/admin/\ncreate_doctor.php" as V
control "controllers/\nDoctorController.php\n::createDoctor()" as C
control "services/\nMailService.php\n::sendTempPassword()" as MS
entity "models/\nDoctorModel.php" as E
database "Railway DB\n(tablas: usuarios, maestro)" as BD

== POST controllers/DoctorController.php?action=create ==

ADM -> V : Envía formulario\nPOST: nombre, correo, cmp,\nespecialidad, esp_nueva, password_temp
V -> C : HTTP POST a DoctorController::createDoctor()

C -> C : Extrae y limpia campos.\nValida obligatorios y formato email.\nValida longitud de password_temp (>= 6)

alt Campos vacíos o inválidos
    C -> C : $_SESSION['flash_errors'] = [...]
    C --> V : HTTP 302 Redirect a\nviews/admin/create_doctor.php
    V --> ADM : Muestra alertas de error\ncon $_SESSION['flash_errors']
else Datos válidos
    C -> E : DoctorModel::existsByEmail($correo)\nDoctorModel::existsByCMP($cmp)
    E -> BD : SELECT id FROM usuarios\nWHERE correo=? / cmp=? LIMIT 1
    BD --> E : row / false
    E --> C : true / false

    alt Correo o CMP ya registrado
        C -> C : $_SESSION['flash_errors'] = [...]
        C --> V : HTTP 302 Redirect a\nviews/admin/create_doctor.php
        V --> ADM : Muestra alertas de duplicidad
    else Disponibles
        alt especialidad == '__nueva__'
            C -> E : DoctorModel::addSpecialty($esp_nueva)
            E -> BD : INSERT INTO maestro (tipo, codigo,\ndescripcion, orden) VALUES (...)
        end
        
        C -> C : $hash = password_hash(\n  $password_temp, PASSWORD_BCRYPT\n)
        C -> E : DoctorModel::create([\n  'nombre' => $nombre,\n  'email' => $correo,\n  'cmp' => $cmp,\n  'especialidad' => $especialidad_final,\n  'password' => $hash,\n  'establecimiento_id' => $est_id\n])
        E -> BD : INSERT INTO usuarios (nombre, correo,\npassword, rol_codigo, cmp, especialidad,\nestablecimiento_id, activo, es_password_temporal)\nVALUES (?, ?, ?, 'MED', ?, ?, ?, 1, 1)
        BD --> E : INSERT OK — lastInsertId()
        E --> C : $lastInsertId

        C -> MS : MailService::sendTempPassword(\n  $correo, $nombre, $password_temp\n)

        alt SMTP responde 250 OK
            MS --> C : return true
            C -> C : $_SESSION['flash_success'] = \n"Cuenta creada. Contraseña enviada..."
            C --> V : HTTP 302 Redirect a\nviews/admin/doctor.php
            V --> ADM : Muestra tabla con el nuevo\nmédico y alerta verde de éxito
        else SMTP falla / sin configurar
            MS --> C : return false
            C -> C : $_SESSION['flash_success'] = "Creado exitosamente..."\n$_SESSION['flash_temp_pass'] = $password_temp
            C --> V : HTTP 302 Redirect a\nviews/admin/create_doctor.php
            V --> ADM : Muestra alerta de éxito y\ncuadro azul con la contraseña\ntemporal para entrega manual
        end
    end
end

@enduml


' ============================================================
' RF-02: Iniciar Sesión
' ============================================================
@startuml RF02_Diseno_IniciarSesion
title RF-02: Iniciar Sesión [Diseño]

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ArrowColor #000000
skinparam SequenceLifeLineBorderColor #888888

actor "Usuario\n(Médico / Admin / SuperAdmin)" as USR

boundary "views/auth/\nlogin.php" as V_LOGIN
boundary "views/auth/\nchange_password.php" as V_CP
control "controllers/\nAuthController.php\n::login()" as C
control "controllers/\nAuthController.php\n::changePassword()" as C_CP
entity "models/\nAuthModel.php" as E
database "Railway DB\n(tabla: usuarios)" as BD

== GET views/auth/login.php ==

USR -> V_LOGIN : HTTP GET views/auth/login.php
V_LOGIN --> USR : HTTP 200 — Formulario:\n<form method="POST"\n  action="...AuthController.php?action=login">\n  <input name="email">\n  <input name="password" type="password">\n  (muestra $_SESSION['login_error'] si existe)

== POST controllers/AuthController.php?action=login ==

USR -> V_LOGIN : Submit formulario\nPOST: email, password
V_LOGIN -> C : HTTP POST AuthController.php?action=login

C -> C : $email = trim($_POST['email'] ?? '')\n$password = $_POST['password'] ?? ''\nif (empty($email) || empty($password)):

alt Campos vacíos
    C -> C : $_SESSION['login_error'] =\n  "Por favor ingrese correo y contraseña."
    C --> V_LOGIN : HTTP 302 Redirect\n→ views/auth/login.php
    V_LOGIN --> USR : Muestra alerta de error
else Campos presentes
    C -> E : AuthModel::getUserByEmail($email)
    E -> BD : SELECT * FROM usuarios\nWHERE correo = :correo\nAND activo = 1 LIMIT 1
    BD --> E : row / false
    E --> C : $user[] / false

    alt Usuario no encontrado (false)
        C -> C : $_SESSION['login_error'] =\n  "Credenciales incorrectas. Verifique\n  su correo y contraseña."
        C --> V_LOGIN : HTTP 302 Redirect\n→ views/auth/login.php
        V_LOGIN --> USR : Muestra alerta de error genérico
    else Usuario encontrado
        C -> C : password_verify($password, $user['password'])

        alt Hash no coincide
            C -> C : $_SESSION['login_error'] =\n  "Credenciales incorrectas..."
            C --> V_LOGIN : HTTP 302 Redirect\n→ views/auth/login.php
            V_LOGIN --> USR : Muestra alerta de error genérico
        else Hash coincide
            C -> C : Verifica $user['activo'] == 1

            alt activo == 0
                C -> C : $_SESSION['login_error'] =\n  "Su cuenta aún no ha sido aprobada\n  por el administrador."
                C --> V_LOGIN : HTTP 302 Redirect\n→ views/auth/login.php
                V_LOGIN --> USR : Muestra alerta cuenta inactiva
            else activo == 1 — Sesión exitosa
                C -> E : AuthModel::updateLastAccess($user['id'])
                E -> BD : UPDATE usuarios\nSET ultimo_acceso = NOW()\nWHERE id = :id
                BD --> E : OK

                C -> C : $_SESSION['user_id'] = $user['id']\n$_SESSION['rol_codigo'] = $user['rol_codigo']\n$_SESSION['nombre'] = $user['nombre']\n$_SESSION['establecimiento_id'] = $user['establecimiento_id']\n$_SESSION['es_password_temporal'] = (bool)$user['es_password_temporal']\n$_SESSION['last_activity'] = time()

                alt $user['es_password_temporal'] == true
                    C --> V_LOGIN : HTTP 302 Redirect\n→ views/auth/change_password.php
                    V_LOGIN --> USR : Redirige a pantalla de\ncambio de contraseña obligatorio

                    == POST controllers/AuthController.php?action=change_password ==

                    USR -> V_CP : Ingresa nueva contraseña\ny confirmación
                    V_CP -> C_CP : HTTP POST AuthController.php?action=change_password
                    C_CP -> C_CP : $nueva = $_POST['nueva_password']\n$confirma = $_POST['confirma_password']\nif (strlen($nueva) < 6):

                    alt Contraseña < 6 chars
                        C_CP -> C_CP : $_SESSION['cp_error'] =\n  "La contraseña debe tener al menos 6 caracteres."
                        C_CP --> V_CP : HTTP 302 Redirect\n→ views/auth/change_password.php
                        V_CP --> USR : Muestra mensaje de error
                    else Contraseñas no coinciden
                        C_CP -> C_CP : if ($nueva !== $confirma):\n  $_SESSION['cp_error'] =\n  "Las contraseñas no coinciden."
                        C_CP --> V_CP : HTTP 302 Redirect
                        V_CP --> USR : Muestra mensaje de error
                    else Contraseña válida
                        C_CP -> C_CP : $hash = password_hash($nueva, PASSWORD_BCRYPT)
                        C_CP -> E : AuthModel::updatePassword(\n  $_SESSION['user_id'], $hash)
                        E -> BD : UPDATE usuarios\nSET password = :password,\nes_password_temporal = 0\nWHERE id = :id
                        BD --> E : UPDATE OK
                        C_CP -> C_CP : $_SESSION['es_password_temporal'] = false\nredirectByRole($_SESSION['rol_codigo'])
                        C_CP --> V_CP : HTTP 302 Redirect según rol
                        V_CP --> USR : Accede al panel correspondiente
                    end

                else $user['es_password_temporal'] == false
                    C -> C : redirectByRole($user['rol_codigo']):\n  'SAD' → views/superadmin/index.php\n  'ADM' → views/admin/index.php\n  'MED' → views/medico/index.php
                    C --> V_LOGIN : HTTP 302 Redirect según rol
                    V_LOGIN --> USR : Accede al panel correspondiente
                end
            end
        end
    end
end

@enduml


' ============================================================
' RF-03: Gestionar Médicos Activos del Establecimiento
' ============================================================
@startuml RF03_Diseno_GestionarMedicos_Actualizado
title RF-03: Gestionar Médicos Activos del Establecimiento [Diseño Actualizado]

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ArrowColor #000000
skinparam SequenceLifeLineBorderColor #888888

actor "Administrador\n(Frontend)" as ADM

boundary "views/admin/\ndoctor.php" as V
boundary "Pop-up DOM\n#modal-edit" as MEdit
boundary "Pop-up DOM\n#modal-reset" as MReset
control "controllers/\nDoctorController.php\n::editDoctor()\n::resetPassword()\n::deactivate()" as C
control "utils/\nPasswordHelper.php\n::generateTemp()" as PH
control "services/\nMailService.php\n::sendResetPassword()" as MS
entity "models/\nDoctorModel.php" as E
database "Railway DB\n(tabla: usuarios)" as BD

== GET views/admin/doctor.php ==

ADM -> V : HTTP GET /admin/doctor.php
V -> E : DoctorModel::getActiveDoctorsByEstablishments($est_ids[])
E -> BD : SELECT u.id, u.nombre, u.correo, u.cmp,\nu.especialidad, u.ultimo_acceso,\nu.es_password_temporal, u.establecimiento_id,\ne.nombre AS est_nombre\nFROM usuarios u\nLEFT JOIN establecimientos e ON e.id=u.establecimiento_id\nWHERE u.rol_codigo='MED' AND u.activo=1\nAND u.establecimiento_id IN (?) ORDER BY e.nombre, u.nombre
BD --> E : rows[] (PDO::FETCH_ASSOC)
E --> V : array $activos
V --> ADM : HTTP 200 OK HTML\nRenderiza <table id="doctorsTable">\nModales #modal-edit y #modal-reset\nembebidos en el mismo doctor.php

== POST controllers/DoctorController.php?action=edit ==

ADM -> V : Clic "Editar" en la tabla
V -> MEdit : Despliega modal de edición
ADM -> MEdit : Ingresa nuevos datos y hace submmit
MEdit -> C : fetch('?action=edit') via FormData\n{edit_id: int, nombre: string, correo: string,\n cmp: string, especialidad: string}
C -> E : DoctorModel::existsByEmail($correo, $edit_id)
E -> BD : SELECT id FROM usuarios\nWHERE correo=? AND id!=? LIMIT 1
BD --> E : row / false
E --> C : boolean

alt existsByEmail == true

    C --> MEdit : HTTP 200 Content-Type: application/json\n{"success": false, "message": "El correo ya está en uso por otro médico."}
    MEdit --> ADM : JavaScript muestra toastify/alerta de error

else existsByEmail == false

    C -> E : DoctorModel::existsByCMP($cmp, $edit_id)
    E -> BD : SELECT id FROM usuarios WHERE cmp=?\nAND rol_codigo='MED' AND id!=?\nLIMIT 1
    BD --> E : row / false
    E --> C : boolean

    alt existsByCMP == true

        C --> MEdit : HTTP 200 Content-Type: application/json\n{"success": false, "message": "El CMP ya está en uso por otro médico."}
        MEdit --> ADM : JavaScript muestra toastify/alerta de error

    else existsByCMP == false

        C -> E : DoctorModel::updateDoctor($edit_id, $est_id, $data)
        E -> BD : UPDATE usuarios SET nombre=?, correo=?,\ncmp=?, especialidad=? WHERE id=?\nAND establecimiento_id=? AND rol_codigo='MED'
        BD --> E : PDOStatement::execute() OK
        E --> C : boolean true

        C --> MEdit : HTTP 200 Content-Type: application/json\n{"success": true}
        MEdit -> V : Cierra modal y dispara\nwindow.location.reload()
        V --> ADM : Toastify "Médico actualizado exitosamente"

    end
end

== POST controllers/DoctorController.php?action=reset ==

ADM -> V : Clic "Resetear contraseña" en la tabla
V -> MReset : Despliega modal de confirmación
ADM -> MReset : Clic "Confirmar"
MReset -> C : fetch('?action=reset') via FormData\n{reset_id: int}
C -> E : DoctorModel::findById($reset_id, $est_id)
E -> BD : SELECT * FROM usuarios WHERE id=? AND establecimiento_id=?
BD --> E : row(doctor)
E --> C : array $doctor (contiene email, nombre)

C -> PH : PasswordHelper::generateTemp(8)
PH --> C : string $tempPass (ej. A1B2c3D4)

C -> C : $hash = password_hash($tempPass, PASSWORD_BCRYPT)

C -> E : DoctorModel::resetPassword($reset_id, $est_id, $hash)
E -> BD : UPDATE usuarios SET password=?, es_password_temporal=1\nWHERE id=? AND establecimiento_id=?
BD --> E : PDOStatement::execute() OK
E --> C : boolean true

C -> MS : MailService::sendResetPassword($doctor['correo'], $doctor['nombre'], $tempPass)
MS -> MS : PHPMailer::send() a SMTP
MS --> C : boolean

alt Mailer successfully sent

    C --> MReset : HTTP 200 Content-Type: application/json\n{"success": true}
    MReset -> V : Cierra modal y dispara\nwindow.location.reload()
    V --> ADM : Tabla recargada con Toastify de éxito

else Mailer threw Exception

    C --> MReset : HTTP 200 Content-Type: application/json\n{"success": false, "message": "No se pudo enviar el correo de recuperación..."}
    MReset --> ADM : JavaScript muestra toastify de error

end

== POST controllers/DoctorController.php?action=deactivate ==

ADM -> V : Form submit nativo <form method="POST">
V -> C : HTTP POST payload: {target_id: int}
C -> E : DoctorModel::deactivate($target_id, $est_id)
E -> BD : UPDATE usuarios SET activo=0 WHERE id=?\nAND establecimiento_id=? AND rol_codigo='MED'
BD --> E : PDOStatement::execute() OK
E --> C : boolean true

C -> C : $_SESSION['flash_success'] = "médico desactivado"
C --> V : HTTP 302 Redirect Location: doctor.php
V --> ADM : Renderiza tabla sin médico desactivado

@enduml

