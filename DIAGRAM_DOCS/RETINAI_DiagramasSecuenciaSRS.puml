@startuml RF01_SRS_CrearCuentaOftalmologo

title RF-01: Crear Cuenta de Oftalmólogo

actor "Administrador" as Admin
participant "Vista (views/admin/create_doctor.php):\nGestión de Médicos" as Vista
participant "Control (controllers/DoctorController.php):\nCuenta Médico" as Control
participant "Servicio (services/MailService.php):\nNotificación por Correo" as Mail
entity "Entidad (models/DoctorModel.php):\nMédico" as Entidad
database "Base de Datos (Railway DB)" as BD

box "Proceso de Registro de Médico" #White
    participant Admin
    participant Vista
    participant Control
    participant Mail
    participant Entidad
    participant BD
end box

Admin -> Vista : Accede a la sección "Médicos"\ny hace clic en "Agregar Médico"
Vista -> Admin : Muestra formulario con campos:\nNombre, Correo, CMP, Especialidad\ny Contraseña temporal
Admin -> Vista : Completa los campos (agregando especialidad\nnueva si requiere) y presiona "Guardar médico"
Vista -> Control : Envía los datos ingresados
Control -> Control : Valida campos obligatorios, formato de\ncorreo y longitud de contraseña (mínimo 6)

alt [Datos incompletos o inválidos]
    Control --> Vista : Informa qué campos tienen error
    Vista -> Admin : Muestra alertas indicando\nlos errores a corregir en el formulario
else [Datos válidos]
    Control -> BD : Verifica que el CMP y el correo\nno estén registrados previamente
    BD --> Control : Resultado de la verificación

    alt [CMP o correo ya registrado]
        Control --> Vista : Informa duplicidad de datos
        Vista -> Admin : Muestra alerta indicando que\nel CMP o correo ya existe en el sistema
    else [Datos disponibles]
        alt [Seleccionó agregar "Nueva Especialidad"]
            Control -> BD : Guarda la nueva especialidad\nen el catálogo del sistema
        end

        Control -> Entidad : Crea la cuenta del médico con estado\n"Activo" y la contraseña temporal cifrada
        Entidad -> BD : Guarda los datos del médico\nasociados al hospital del Administrador
        BD --> Entidad : Confirmación de guardado
        Entidad --> Control : Retorna confirmación

        Control -> Mail : Solicita enviar correo de bienvenida\ncon la contraseña temporal asignada
        
        alt [Correo enviado exitosamente]
            Mail --> Control : Confirma envío
            Control --> Vista : Confirma creación exitosa
            Vista -> Admin : Redirige a la lista de médicos y muestra:\n"Cuenta creada. Contraseña enviada al correo."
        else [Fallo en el servicio de correo]
            Mail --> Control : Informa fallo en envío
            Control --> Vista : Informa creación exitosa pero fallo de correo
            Vista -> Admin : Muestra cuadro azul de advertencia con la\ncontraseña temporal para entrega manual.
        end
    end
end

@enduml

@startuml RF02_SRS_IniciarSesion

title RF-02: Iniciar Sesión

actor "Usuario\n(Médico / Administrador / SuperAdmin)" as Usuario
participant "Página de Acceso\n(views/auth/login.php):\nFormulario de Inicio de Sesión" as PantallaLogin
participant "Página de Cambio de Contraseña\n(views/auth/change_password.php)" as PantallaCP
participant "Control: Acceso\n(controllers/AuthController.php):\nGestión de Autenticación" as Control
entity "Entidad: Usuario\n(models/AuthModel.php):\nUsuario del Sistema" as Entidad
database "Base de Datos (Railway DB)" as BD

box "Proceso de Inicio de Sesión" #White
    participant Usuario
    participant PantallaLogin
    participant PantallaCP
    participant Control
    participant Entidad
    participant BD
end box

Usuario -> PantallaLogin : Accede a la página de inicio de sesión
PantallaLogin --> Usuario : Muestra formulario con campos\ncorreo electrónico y contraseña
Usuario -> PantallaLogin : Ingresa su correo y contraseña,\ny hace clic en "Ingresar"
PantallaLogin -> Control : Envía los datos ingresados
Control -> Control : Verifica que los campos no estén vacíos

alt [Campos vacíos]
    Control --> PantallaLogin : Informa que faltan datos
    PantallaLogin --> Usuario : Muestra aviso:\n"Por favor ingrese correo y contraseña."
else [Campos completos]
    Control -> Entidad : Busca al usuario por correo electrónico
    Entidad -> BD : Consulta si existe un usuario activo con ese correo
    BD --> Entidad : Resultado de la búsqueda
    Entidad --> Control : Datos del usuario o indicación de que no existe

    alt [Correo no registrado]
        Control --> PantallaLogin : Informa error de acceso
        PantallaLogin --> Usuario : Muestra aviso genérico:\n"Credenciales incorrectas. Verifique\nsu correo y contraseña."
    else [Correo encontrado]
        Control -> Control : Compara la contraseña ingresada\ncon la contraseña guardada (encriptada)

        alt [Contraseña incorrecta]
            Control --> PantallaLogin : Informa error de acceso
            PantallaLogin --> Usuario : Muestra el mismo aviso genérico de error
        else [Contraseña correcta]
            Control -> Control : Verifica si la cuenta está activa

            alt [Cuenta desactivada o pendiente de aprobación]
                Control --> PantallaLogin : Informa cuenta inactiva
                PantallaLogin --> Usuario : Muestra aviso:\n"Su cuenta aún no ha sido aprobada\npor el administrador."
            else [Cuenta activa]
                Control -> Entidad : Registra el último acceso del usuario
                Entidad -> BD : Guarda la fecha y hora de acceso
                Control -> Control : Inicia la sesión del usuario\n(guarda sus datos de acceso)

                alt [La cuenta tiene contraseña temporal]
                    Control --> PantallaLogin : Redirige a pantalla de cambio de contraseña
                    PantallaLogin --> Usuario : Muestra mensaje:\n"Debe establecer una nueva contraseña\nantes de continuar"

                    Usuario -> PantallaCP : Ingresa nueva contraseña y la confirma
                    PantallaCP -> Control : Envía nueva contraseña
                    Control -> Control : Verifica que tenga al menos 6 caracteres\ny que ambos campos coincidan

                    alt [Contraseña demasiado corta o no coincide]
                        Control --> PantallaCP : Informa el error
                        PantallaCP --> Usuario : Muestra el mensaje de error correspondiente
                    else [Contraseña válida]
                        Control -> Entidad : Guarda la nueva contraseña y quita la marca de temporal
                        Entidad -> BD : Actualiza la contraseña del usuario
                        BD --> Entidad : Confirmación
                        Control --> PantallaCP : Redirige al panel correspondiente
                        PantallaCP --> Usuario : Accede a su panel de trabajo
                    end

                else [La cuenta tiene contraseña definitiva]
                    Control --> PantallaLogin : Redirige al panel correspondiente según su tipo de usuario
                    PantallaLogin --> Usuario : Accede a su panel:\n- Super Administrador → Panel de gestión global\n- Administrador → Panel del centro oftalmólogico\n- Médico → Panel de análisis retinal
                end
            end
        end
    end
end

@enduml

@startuml RF03_SRS_GestionarMedicos

title RF-03: Gestionar Médicos Activos del Establecimiento

actor "Administrador" as Admin
participant "Vista (views/admin/doctor.php):\nGestión de Médicos" as Vista
participant "Pop-up (views/admin/modal_edit.php):\nEditar Médico" as ModalEdit
participant "Pop-up (views/admin/modal_reset.php):\nResetear Contraseña" as ModalReset
participant "Control (controllers/DoctorController.php):\nCuenta Médico" as Control
participant "Serv. Util (utils/PasswordHelper.php):\nGenerador Contraseñas" as Util
participant "Servicio (services/MailService.php):\nNotificación por Correo" as Mail
entity "Entidad (models/DoctorModel.php):\nMédico" as Entidad
database "Base de Datos (Railway DB)" as BD

box "Proceso de Gestión de Médicos" #White
    participant Admin
    participant Vista
    participant ModalEdit
    participant ModalReset
    participant Control
    participant Util
    participant Mail
    participant Entidad
    participant BD
end box

Admin -> Vista : Selecciona opción "Médicos"
Vista -> Admin : Muestra lista de médicos activos
Admin -> Vista : Elige acción (Editar, Resetear Contraseña o Desactivar)

alt [Editar Médico]
    Admin -> Vista : Clic en "Editar"
    Vista -> ModalEdit : Abre Pop-up de Edición
    ModalEdit -> Admin : Muestra formulario con datos actuales
    Admin -> ModalEdit : Modifica datos y guarda
    ModalEdit -> Control : Envía nuevos datos editados
    Control -> BD : Verifica que correo y CMP no estén duplicados
    
    alt [Duplicidad]
        BD --> Control : Duplicados encontrados
        Control --> ModalEdit : Informa error de duplicidad
        ModalEdit -> Admin : Muestra alerta en el formulario
    else [Datos disponibles]
        BD --> Control : Disponibles
        Control -> Entidad : Actualiza información del médico
        Entidad -> BD : Guarda los cambios (nombre, correo, CMP, especialidad)
        BD --> Entidad : Confirmación
        Entidad --> Control : Ok
        Control --> ModalEdit : Confirmación de actualización
        ModalEdit -> Vista : Cierra Pop-up y recarga
        Vista -> Admin : Muestra mensaje de éxito y tabla actualizada
    end

else [Resetear Contraseña]
    Admin -> Vista : Clic en "Resetear contraseña"
    Vista -> ModalReset : Abre Pop-up de Confirmación
    ModalReset -> Admin : Muestra aviso de reseteo
    Admin -> ModalReset : Confirma reseteo
    ModalReset -> Control : Solicita reseteo
    Control -> Util : Genera nueva contraseña temporal
    Util --> Control : Contraseña temporal generada
    Control -> Entidad : Asigna contraseña al médico y cambia estado temporal
    Entidad -> BD : Guarda nueva clave encriptada
    BD --> Entidad : OK
    Entidad --> Control : OK
    
    Control -> Mail : Envía contraseña temporal por correo
    alt [Correo exitoso]
        Mail --> Control : Envío OK
        Control --> ModalReset : Confirmación de reseteo y envío
        ModalReset -> Vista : Cierra Pop-up y recarga
        Vista -> Admin : Muestra mensaje de éxito
    else [Correo fallido]
        Mail --> Control : Fallo
        Control --> ModalReset : Informa fallo al enviar
        ModalReset -> Admin : Muestra mensaje de error sin recargar tabla
    end

else [Desactivar Acceso]
    Admin -> Vista : Clic en "Desactivar" y confirma
    Vista -> Control : Solicita desactivación
    Control -> Entidad : Cambia el estado del médico a inactivo
    Entidad -> BD : Actualiza estado en BD (activo=0)
    BD --> Entidad : Confirmación
    Entidad --> Control : OK
    Control --> Vista : Confirma desactivación
    Vista -> Admin : Muestra mensaje y retira al médico de la lista
end

@enduml

@startuml RF08_SRS_RegistroCentroOftalmologico

title RF-08: Solicitar Registro de Centro Oftalmológico y Aprobación [Diagrama de Secuencia SRS]

actor "Titular del Centro\nOftalmológico" as Titular
actor "Super Administrador" as SADM
participant "Página Principal\n(index.php)" as Index
participant "Vista: Registro de Centro\n(views/auth/solicitud_registro.php)" as VistaReg
participant "Lógica del Formulario\n(assets/js/auth/solicitud_registro.js)" as JS
participant "Vista: Solicitudes\n(views/superadmin/SolicitudesRegistro.php)" as VistaSAD
participant "Control: Solicitud\n(controllers/SolicitudController.php)" as Control
participant "Servicio: Correo\n(services/MailService.php)" as Mail
database "Base de Datos (Railway DB)" as BD

box "Fase 1: Solicitud de Registro" #White
    participant Titular
    participant Index
    participant VistaReg
    participant JS
    participant Control
    participant Mail
    participant BD
end box

Titular -> Index : Visita la página principal
Index --> Titular : Muestra botón "Registrar centro oftalmológico"
Titular -> Index : Clic en "Registrar centro oftalmológico"\n(enlace a views/auth/solicitud_registro.php)
Index -> VistaReg : Carga el formulario de registro
VistaReg --> Titular : Muestra formulario de registro\n(Datos del centro, titular, correo, evidencias)

Titular -> JS : Llena correo y hace clic en "Enviar código"
JS -> JS : Valida formato del correo antes de enviarlo
JS -> Control : Solicita envío de código de verificación {correo, nombres}
Control -> Control : Genera código de 6 dígitos y lo guarda temporalmente
Control -> Mail : Solicita envío del código al correo del titular
Mail --> Control : Código enviado (o fallo)

alt [No se pudo enviar el correo]
    Control --> JS : Informa fallo de envío
    JS --> VistaReg : Muestra aviso de error al titular
else [Código enviado correctamente]
    Control --> JS : Confirma envío exitoso
    JS --> VistaReg : Habilita campo de código + muestra\ncuenta regresiva de 10 minutos
end

Titular -> VistaReg : Ingresa código recibido en el correo
Titular -> VistaReg : Adjunta evidencias del establecimiento (JPG/PNG/PDF, máx. 200KB c/u)
JS -> JS : Convierte los archivos a formato Base64\ny los asocia al formulario de forma oculta
Titular -> VistaReg : Clic en "Enviar solicitud"
JS -> JS : Valida todos los campos del formulario en el navegador\n(RUC 11 dígitos, DNI 8 dígitos, código 6 dígitos, al menos 1 evidencia)

alt [Datos inválidos en el formulario]
    JS --> VistaReg : Resalta los campos con error y muestra\nel mensaje de qué se debe corregir
    VistaReg --> Titular : Visualiza errores y corrige
else [Datos completos y válidos en el formulario]
    VistaReg -> Control : Envía todos los datos del formulario\más las evidencias adjuntas
    Control -> Control : Valida el código OTP, su vigencia (máx. 10 minutos)\ny el formato de todos los datos recibidos

    alt [Código expirado, incorrecto o datos inválidos]
        Control --> VistaReg : Redirige con mensaje de error
        VistaReg --> Titular : Muestra el error correspondiente
    else [Validaciones correctas]
        Control -> BD : Verifica que el RUC no esté registrado\nni tenga una solicitud en proceso

        alt [RUC ya registrado o solicitud pendiente]
            BD --> Control : Informa duplicado
            Control --> VistaReg : Redirige con mensaje de duplicidad
            VistaReg --> Titular : Muestra aviso de RUC ya existente
        else [RUC disponible]
            BD --> Control : Confirmación de disponibilidad
            Control -> BD : Guarda la solicitud en estado "pendiente"\n(con todos los datos y evidencias)
            BD --> Control : Confirmación de guardado
            Control -> Control : Elimina el código de verificación de la sesión
            Control --> VistaReg : Redirige con mensaje de éxito
            VistaReg --> Titular : Muestra pantalla "¡Solicitud enviada!"\ny enlace para volver al inicio
        end
    end
end

box "Fase 2: Aprobación del Super Administrador" #f8fafc
    participant SADM
    participant VistaSAD
    participant Control
    participant Mail
    participant BD
end box

SADM -> VistaSAD : Accede a "Solicitudes de Registro"
VistaSAD -> BD : Consulta todas las solicitudes (pendientes primero)
BD --> VistaSAD : Lista de solicitudes con sus datos y evidencias
VistaSAD --> SADM : Muestra tabla con botones [✓ Aprobar] [✗ Rechazar]

SADM -> VistaSAD : Revisa evidencias (prevista en ventana emergente)\ny da clic en "✓ Aprobar"
VistaSAD -> Control : Envía la solicitud de aprobación

Control -> BD : Busca si el correo del titular ya tiene\nuna cuenta de Administrador en el sistema
BD --> Control : Resultado de la búsqueda

alt [El titular ya tiene cuenta de Administrador]
    Control -> BD : Crea el nuevo centro oftalmológico y lo vincula\na la cuenta existente del titular
    BD --> Control : Centro creado
    Control -> BD : Marca la solicitud como "aprobada"
    Control -> Mail : Envía correo de aprobación al titular\n(sin generar nueva cuenta)
    Mail --> Control : Correo enviado
else [El titular no tiene cuenta aún]
    Control -> BD : Crea la cuenta de Administrador del titular\n(con contraseña temporal generada automáticamente)
    BD --> Control : Cuenta creada
    Control -> BD : Crea el nuevo centro oftalmológico\ny lo vincula a la nueva cuenta
    BD --> Control : Centro creado
    Control -> BD : Marca la solicitud como "aprobada"
    Control -> Mail : Envía correo de aprobación al titular
    Mail --> Control : Correo enviado
    Control -> Mail : Envía correo con la contraseña temporal\npara que el titular pueda ingresar al sistema
    Mail --> Control : Correo enviado
end

Control --> VistaSAD : Redirige con mensaje de éxito
VistaSAD --> SADM : Muestra alerta verde "Solicitud aprobada\ny credenciales enviadas al titular"

@enduml