@startuml RF01_SRS_CrearCuentaOftalmologo

title RF-01: Crear Cuenta de Oftalmólogo

actor "Administrador" as Admin
participant "Vista (views/admin/create_doctor.php):\nGestión de Médicos" as Vista
participant "Control (controllers/DoctorController.php):\nCuenta Médico" as Control
participant "Servicio (services/MailService.php):\nNotificación por Correo" as Mail
entity "Entidad (models/DoctorModel.php):\nMédico" as Entidad
database "Base de Datos (Railway DB)" as BD

box "Proceso de Registro de Médico" #White
    participant Admin
    participant Vista
    participant Control
    participant Mail
    participant Entidad
    participant BD
end box

Admin -> Vista : Accede a la sección "Médicos"\ny hace clic en "Agregar Médico"
Vista -> Admin : Muestra formulario con campos:\nNombre, Correo, CMP, Especialidad\ny Contraseña temporal
Admin -> Vista : Completa los campos (agregando especialidad\nnueva si requiere) y presiona "Guardar médico"
Vista -> Control : Envía los datos ingresados
Control -> Control : Valida campos obligatorios, formato de\ncorreo y longitud de contraseña (mínimo 6)

alt [Datos incompletos o inválidos]
    Control --> Vista : Informa qué campos tienen error
    Vista -> Admin : Muestra alertas indicando\nlos errores a corregir en el formulario
else [Datos válidos]
    Control -> BD : Verifica que el CMP y el correo\nno estén registrados previamente
    BD --> Control : Resultado de la verificación

    alt [CMP o correo ya registrado]
        Control --> Vista : Informa duplicidad de datos
        Vista -> Admin : Muestra alerta indicando que\nel CMP o correo ya existe en el sistema
    else [Datos disponibles]
        alt [Seleccionó agregar "Nueva Especialidad"]
            Control -> BD : Guarda la nueva especialidad\nen el catálogo del sistema
        end

        Control -> Entidad : Crea la cuenta del médico con estado\n"Activo" y la contraseña temporal cifrada
        Entidad -> BD : Guarda los datos del médico\nasociados al hospital del Administrador
        BD --> Entidad : Confirmación de guardado
        Entidad --> Control : Retorna confirmación

        Control -> Mail : Solicita enviar correo de bienvenida\ncon la contraseña temporal asignada
        
        alt [Correo enviado exitosamente]
            Mail --> Control : Confirma envío
            Control --> Vista : Confirma creación exitosa
            Vista -> Admin : Redirige a la lista de médicos y muestra:\n"Cuenta creada. Contraseña enviada al correo."
        else [Fallo en el servicio de correo]
            Mail --> Control : Informa fallo en envío
            Control --> Vista : Informa creación exitosa pero fallo de correo
            Vista -> Admin : Muestra cuadro azul de advertencia con la\ncontraseña temporal para entrega manual.
        end
    end
end

@enduml

@startuml RF02_SRS_IniciarSesion

title RF-02: Iniciar Sesión

actor "Usuario\n(Médico / Administrador / SuperAdmin)" as Usuario
participant "Página de Acceso\n(views/auth/login.php):\nFormulario de Inicio de Sesión" as PantallaLogin
participant "Página de Cambio de Contraseña\n(views/auth/change_password.php)" as PantallaCP
participant "Control: Acceso\n(controllers/AuthController.php):\nGestión de Autenticación" as Control
entity "Entidad: Usuario\n(models/AuthModel.php):\nUsuario del Sistema" as Entidad
database "Base de Datos (Railway DB)" as BD

box "Proceso de Inicio de Sesión" #White
    participant Usuario
    participant PantallaLogin
    participant PantallaCP
    participant Control
    participant Entidad
    participant BD
end box

Usuario -> PantallaLogin : Accede a la página de inicio de sesión
PantallaLogin --> Usuario : Muestra formulario con campos\ncorreo electrónico y contraseña
Usuario -> PantallaLogin : Ingresa su correo y contraseña,\ny hace clic en "Ingresar"
PantallaLogin -> Control : Envía los datos ingresados
Control -> Control : Verifica que los campos no estén vacíos

alt [Campos vacíos]
    Control --> PantallaLogin : Informa que faltan datos
    PantallaLogin --> Usuario : Muestra aviso:\n"Por favor ingrese correo y contraseña."
else [Campos completos]
    Control -> Entidad : Busca al usuario por correo electrónico
    Entidad -> BD : Consulta si existe un usuario activo con ese correo
    BD --> Entidad : Resultado de la búsqueda
    Entidad --> Control : Datos del usuario o indicación de que no existe

    alt [Correo no registrado]
        Control --> PantallaLogin : Informa error de acceso
        PantallaLogin --> Usuario : Muestra aviso genérico:\n"Credenciales incorrectas. Verifique\nsu correo y contraseña."
    else [Correo encontrado]
        Control -> Control : Compara la contraseña ingresada\ncon la contraseña guardada (encriptada)

        alt [Contraseña incorrecta]
            Control --> PantallaLogin : Informa error de acceso
            PantallaLogin --> Usuario : Muestra el mismo aviso genérico de error
        else [Contraseña correcta]
            Control -> Control : Verifica si la cuenta está activa

            alt [Cuenta desactivada o pendiente de aprobación]
                Control --> PantallaLogin : Informa cuenta inactiva
                PantallaLogin --> Usuario : Muestra aviso:\n"Su cuenta aún no ha sido aprobada\npor el administrador."
            else [Cuenta activa]
                Control -> Entidad : Registra el último acceso del usuario
                Entidad -> BD : Guarda la fecha y hora de acceso
                Control -> Control : Inicia la sesión del usuario\n(guarda sus datos de acceso)

                alt [La cuenta tiene contraseña temporal]
                    Control --> PantallaLogin : Redirige a pantalla de cambio de contraseña
                    PantallaLogin --> Usuario : Muestra mensaje:\n"Debe establecer una nueva contraseña\nantes de continuar"

                    Usuario -> PantallaCP : Ingresa nueva contraseña y la confirma
                    PantallaCP -> Control : Envía nueva contraseña
                    Control -> Control : Verifica que tenga al menos 6 caracteres\ny que ambos campos coincidan

                    alt [Contraseña demasiado corta o no coincide]
                        Control --> PantallaCP : Informa el error
                        PantallaCP --> Usuario : Muestra el mensaje de error correspondiente
                    else [Contraseña válida]
                        Control -> Entidad : Guarda la nueva contraseña y quita la marca de temporal
                        Entidad -> BD : Actualiza la contraseña del usuario
                        BD --> Entidad : Confirmación
                        Control --> PantallaCP : Redirige al panel correspondiente
                        PantallaCP --> Usuario : Accede a su panel de trabajo
                    end

                else [La cuenta tiene contraseña definitiva]
                    Control --> PantallaLogin : Redirige al panel correspondiente según su tipo de usuario
                    PantallaLogin --> Usuario : Accede a su panel:\n- Super Administrador → Panel de gestión global\n- Administrador → Panel del centro oftalmólogico\n- Médico → Panel de análisis retinal
                end
            end
        end
    end
end

@enduml

@startuml RF03_SRS_GestionarMedicos

title RF-03: Gestionar Médicos Activos del Establecimiento

actor "Administrador" as Admin
participant "Vista (views/admin/doctor.php):\nGestión de Médicos" as Vista
participant "Pop-up (views/admin/modal_edit.php):\nEditar Médico" as ModalEdit
participant "Pop-up (views/admin/modal_reset.php):\nResetear Contraseña" as ModalReset
participant "Control (controllers/DoctorController.php):\nCuenta Médico" as Control
participant "Serv. Util (utils/PasswordHelper.php):\nGenerador Contraseñas" as Util
participant "Servicio (services/MailService.php):\nNotificación por Correo" as Mail
entity "Entidad (models/DoctorModel.php):\nMédico" as Entidad
database "Base de Datos (Railway DB)" as BD

box "Proceso de Gestión de Médicos" #White
    participant Admin
    participant Vista
    participant ModalEdit
    participant ModalReset
    participant Control
    participant Util
    participant Mail
    participant Entidad
    participant BD
end box

Admin -> Vista : Selecciona opción "Médicos"
Vista -> Admin : Muestra lista de médicos activos
Admin -> Vista : Elige acción (Editar, Resetear Contraseña o Desactivar)

alt [Editar Médico]
    Admin -> Vista : Clic en "Editar"
    Vista -> ModalEdit : Abre Pop-up de Edición
    ModalEdit -> Admin : Muestra formulario con datos actuales
    Admin -> ModalEdit : Modifica datos y guarda
    ModalEdit -> Control : Envía nuevos datos editados
    Control -> BD : Verifica que correo y CMP no estén duplicados
    
    alt [Duplicidad]
        BD --> Control : Duplicados encontrados
        Control --> ModalEdit : Informa error de duplicidad
        ModalEdit -> Admin : Muestra alerta en el formulario
    else [Datos disponibles]
        BD --> Control : Disponibles
        Control -> Entidad : Actualiza información del médico
        Entidad -> BD : Guarda los cambios (nombre, correo, CMP, especialidad)
        BD --> Entidad : Confirmación
        Entidad --> Control : Ok
        Control --> ModalEdit : Confirmación de actualización
        ModalEdit -> Vista : Cierra Pop-up y recarga
        Vista -> Admin : Muestra mensaje de éxito y tabla actualizada
    end

else [Resetear Contraseña]
    Admin -> Vista : Clic en "Resetear contraseña"
    Vista -> ModalReset : Abre Pop-up de Confirmación
    ModalReset -> Admin : Muestra aviso de reseteo
    Admin -> ModalReset : Confirma reseteo
    ModalReset -> Control : Solicita reseteo
    Control -> Util : Genera nueva contraseña temporal
    Util --> Control : Contraseña temporal generada
    Control -> Entidad : Asigna contraseña al médico y cambia estado temporal
    Entidad -> BD : Guarda nueva clave encriptada
    BD --> Entidad : OK
    Entidad --> Control : OK
    
    Control -> Mail : Envía contraseña temporal por correo
    alt [Correo exitoso]
        Mail --> Control : Envío OK
        Control --> ModalReset : Confirmación de reseteo y envío
        ModalReset -> Vista : Cierra Pop-up y recarga
        Vista -> Admin : Muestra mensaje de éxito
    else [Correo fallido]
        Mail --> Control : Fallo
        Control --> ModalReset : Informa fallo al enviar
        ModalReset -> Admin : Muestra mensaje de error sin recargar tabla
    end

else [Desactivar Acceso]
    Admin -> Vista : Clic en "Desactivar" y confirma
    Vista -> Control : Solicita desactivación
    Control -> Entidad : Cambia el estado del médico a inactivo
    Entidad -> BD : Actualiza estado en BD (activo=0)
    BD --> Entidad : Confirmación
    Entidad --> Control : OK
    Control --> Vista : Confirma desactivación
    Vista -> Admin : Muestra mensaje y retira al médico de la lista
end

@enduml

@startuml RF08_SRS_RegistroCentroOftalmologico

title RF-08: Solicitar Registro de Centro Oftalmológico y Aprobación [Diagrama de Secuencia SRS]

actor "Titular del Centro\nOftalmológico" as Titular
actor "Super Administrador" as SADM
participant "Página Principal\n(index.php)" as Index
participant "Vista: Registro de Centro\n(views/auth/solicitud_registro.php)" as VistaReg
participant "Lógica del Formulario\n(assets/js/auth/solicitud_registro.js)" as JS
participant "Vista: Solicitudes\n(views/superadmin/SolicitudesRegistro.php)" as VistaSAD
participant "Control: Solicitud\n(controllers/SolicitudController.php)" as Control
participant "Servicio: Correo\n(services/MailService.php)" as Mail
database "Base de Datos (Railway DB)" as BD

box "Fase 1: Solicitud de Registro" #White
    participant Titular
    participant Index
    participant VistaReg
    participant JS
    participant Control
    participant Mail
    participant BD
end box

Titular -> Index : Visita la página principal
Index --> Titular : Muestra botón "Registrar centro oftalmológico"
Titular -> Index : Clic en "Registrar centro oftalmológico"\n(enlace a views/auth/solicitud_registro.php)
Index -> VistaReg : Carga el formulario de registro
VistaReg --> Titular : Muestra formulario de registro\n(Datos del centro, titular, correo, evidencias)

Titular -> JS : Llena correo y hace clic en "Enviar código"
JS -> JS : Valida formato del correo antes de enviarlo
JS -> Control : Solicita envío de código de verificación {correo, nombres}
Control -> Control : Genera código de 6 dígitos y lo guarda temporalmente
Control -> Mail : Solicita envío del código al correo del titular
Mail --> Control : Código enviado (o fallo)

alt [No se pudo enviar el correo]
    Control --> JS : Informa fallo de envío
    JS --> VistaReg : Muestra aviso de error al titular
else [Código enviado correctamente]
    Control --> JS : Confirma envío exitoso
    JS --> VistaReg : Habilita campo de código + muestra\ncuenta regresiva de 10 minutos
end

Titular -> VistaReg : Ingresa código recibido en el correo
Titular -> VistaReg : Adjunta evidencias del establecimiento (JPG/PNG/PDF, máx. 200KB c/u)
JS -> JS : Convierte los archivos a formato Base64\ny los asocia al formulario de forma oculta
Titular -> VistaReg : Clic en "Enviar solicitud"
JS -> JS : Valida todos los campos del formulario en el navegador\n(RUC 11 dígitos, DNI 8 dígitos, código 6 dígitos, al menos 1 evidencia)

alt [Datos inválidos en el formulario]
    JS --> VistaReg : Resalta los campos con error y muestra\nel mensaje de qué se debe corregir
    VistaReg --> Titular : Visualiza errores y corrige
else [Datos completos y válidos en el formulario]
    VistaReg -> Control : Envía todos los datos del formulario\más las evidencias adjuntas
    Control -> Control : Valida el código OTP, su vigencia (máx. 10 minutos)\ny el formato de todos los datos recibidos

    alt [Código expirado, incorrecto o datos inválidos]
        Control --> VistaReg : Redirige con mensaje de error
        VistaReg --> Titular : Muestra el error correspondiente
    else [Validaciones correctas]
        Control -> BD : Verifica que el RUC no esté registrado\nni tenga una solicitud en proceso

        alt [RUC ya registrado o solicitud pendiente]
            BD --> Control : Informa duplicado
            Control --> VistaReg : Redirige con mensaje de duplicidad
            VistaReg --> Titular : Muestra aviso de RUC ya existente
        else [RUC disponible]
            BD --> Control : Confirmación de disponibilidad
            Control -> BD : Guarda la solicitud en estado "pendiente"\n(con todos los datos y evidencias)
            BD --> Control : Confirmación de guardado
            Control -> Control : Elimina el código de verificación de la sesión
            Control --> VistaReg : Redirige con mensaje de éxito
            VistaReg --> Titular : Muestra pantalla "¡Solicitud enviada!"\ny enlace para volver al inicio
        end
    end
end

box "Fase 2: Aprobación del Super Administrador" #f8fafc
    participant SADM
    participant VistaSAD
    participant Control
    participant Mail
    participant BD
end box

SADM -> VistaSAD : Accede a "Solicitudes de Registro"
VistaSAD -> BD : Consulta todas las solicitudes (pendientes primero)
BD --> VistaSAD : Lista de solicitudes con sus datos y evidencias
VistaSAD --> SADM : Muestra tabla con botones [✓ Aprobar] [✗ Rechazar]

SADM -> VistaSAD : Revisa evidencias (prevista en ventana emergente)\ny da clic en "✓ Aprobar"
VistaSAD -> Control : Envía la solicitud de aprobación

Control -> BD : Busca si el correo del titular ya tiene\nuna cuenta de Administrador en el sistema
BD --> Control : Resultado de la búsqueda

alt [El titular ya tiene cuenta de Administrador]
    Control -> BD : Crea el nuevo centro oftalmológico y lo vincula\na la cuenta existente del titular
    BD --> Control : Centro creado
    Control -> BD : Marca la solicitud como "aprobada"
    Control -> Mail : Envía correo de aprobación al titular\n(sin generar nueva cuenta)
    Mail --> Control : Correo enviado
else [El titular no tiene cuenta aún]
    Control -> BD : Crea la cuenta de Administrador del titular\n(con contraseña temporal generada automáticamente)
    BD --> Control : Cuenta creada
    Control -> BD : Crea el nuevo centro oftalmológico\ny lo vincula a la nueva cuenta
    BD --> Control : Centro creado
    Control -> BD : Marca la solicitud como "aprobada"
    Control -> Mail : Envía correo de aprobación al titular
    Mail --> Control : Correo enviado
    Control -> Mail : Envía correo con la contraseña temporal\npara que el titular pueda ingresar al sistema
    Mail --> Control : Correo enviado
end

Control --> VistaSAD : Redirige con mensaje de éxito
VistaSAD --> SADM : Muestra alerta verde "Solicitud aprobada\ny credenciales enviadas al titular"
@enduml

' ============================================================
' RF-04: Gestión de centro oftalmológico (Edición)
' ============================================================
@startuml RF04_SRS_GestionCentroOftalmologico
title RF-04: Gestión de Centro Oftalmológico (Edición) [SRS]

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ArrowColor #000000
skinparam SequenceLifeLineBorderColor #888888

actor "Super Administrador" as SADM
participant "Interfaz: Detalles del\nEstablecimiento\n(detalles_establecimientos.php)" as Vista
participant "Control: Gestión de\nEstablecimiento\n(EstablecimientoController.php)" as Control
participant "Entidad: Establecimiento\n(EstablecimientoModel.php)" as Entidad
participant "Servicio de Correo\n(MailService.php)" as Correo
database "Base de Datos" as BD

SADM -> Vista : Clic en "Ver/Editar" sobre un establecimiento
Vista -> Entidad : Solicita datos del establecimiento, titular y médicos
Entidad -> BD : Consulta información del centro y sus usuarios
BD --> Entidad : Datos recuperados
Entidad --> Vista : Retorna datos
Vista --> SADM : Muestra formulario de edición con los datos actuales

SADM -> Vista : Modifica datos (Nombre, RUC, Dirección, etc.)\ny hace clic en "Guardar Cambios"
Vista -> Control : Envía los nuevos datos (POST al controlador)

Control -> Control : Valida que el nombre no esté vacío

alt [Datos inválidos]
    Control --> Vista : Redirige con mensaje de error en sesión
    Vista --> SADM : Muestra alerta de error
else [Datos válidos]
    Control -> Entidad : Solicita actualizar los datos del establecimiento
    Entidad -> BD : Actualiza los datos del centro en el sistema
    BD --> Entidad : Confirmación de actualización exitosa
    Entidad --> Control : OK

    Control -> Entidad : Solicita datos del titular para notificación
    Entidad --> Control : Datos del titular (Nombre, Correo)

    Control -> Correo : Solicita enviar notificación al titular
    Correo --> Control : Correo de "Datos Actualizados" enviado

    Control --> Vista : Redirige con mensaje de éxito en sesión
    Vista --> SADM : Muestra alerta: "Establecimiento actualizado correctamente"
end

@enduml

' ============================================================
' RF-05: Procesar Análisis de Imagen Retinal (CU-05)
' ============================================================
@startuml RF05_SRS_AnalisisRetinal

title RF-05: Procesar Análisis de Imagen Retinal [Diagrama de Secuencia SRS]

actor "Médico Oftalmólogo" as Medico
participant "Pantalla: Nuevo Análisis\n(views/medico/nuevoanalisis.php):\nFormulario de Análisis Retinal" as Vista
participant "Control: Análisis\n(controllers/AnalisisController.php):\nGestión del Análisis" as Control
participant "Control: Paciente\n(controllers/PacienteController.php):\nIdentificación de Paciente" as CtrlPac
participant "Control: Carpeta\n(controllers/CarpetaController.php):\nGestión de Carpetas" as CtrlCarpeta
entity "Modelo CNN\n(API Flask - EC2):\nMotor de Diagnóstico IA" as CNN
entity "Entidad: Análisis\n(models/AnalisisModel.php):\nRegistro de Análisis" as EntAnalisis
entity "Entidad: Paciente\n(models/PacienteModel.php):\nDatos del Paciente" as EntPac
database "Base de Datos (Railway DB)" as BD

box "Proceso de Análisis Retinal" #White
    participant Medico
    participant Vista
    participant Control
    participant CtrlPac
    participant CtrlCarpeta
    participant CNN
    participant EntAnalisis
    participant EntPac
    participant BD
end box

== Paso 1: Cargar Retinografía ==

Medico -> Vista : Accede a "Nuevo análisis" desde el menú lateral
Vista --> Medico : Muestra la pantalla con el indicador de pasos\n(① Cargar imagen → ② Procesando → ③ Resultado)\ny el área de carga de imagen

Medico -> Vista : Selecciona o arrastra la retinografía\n(formato JPG o PNG, máximo 10 MB)
Vista -> Vista : Verifica formato y tamaño del archivo

alt [Formato no válido (no es JPG ni PNG)]
    Vista --> Medico : Muestra alerta:\n"Formato no permitido. Por favor sube\nuna imagen en formato JPG o PNG."
else [Archivo demasiado grande (más de 10 MB)]
    Vista --> Medico : Muestra alerta:\n"El archivo supera el tamaño máximo\npermitido de 10 MB."
else [Archivo válido]
    Vista -> Vista : Evalúa si la imagen tiene\nsuficiente nitidez y contraste

    alt [Imagen con baja calidad]
        Vista --> Medico : Muestra aviso en amarillo:\n"La imagen puede presentar baja calidad.\nLos resultados podrían ser menos precisos.\nPuede continuar el análisis."
    end

    Vista --> Medico : Muestra vista previa de la retinografía,\nel nombre del archivo y habilita el botón\n"Analizar imagen"
end

== Paso 2: Identificar al Paciente ==

Medico -> Vista : Ingresa el DNI del paciente (ej. 71987400)\ny presiona "Buscar / registrar paciente"
Vista -> CtrlPac : Envía el DNI para identificar al paciente
CtrlPac -> CtrlPac : Verifica que el DNI tenga exactamente 8 dígitos numéricos

alt [DNI inválido]
    CtrlPac --> Vista : Informa que el DNI no tiene el formato correcto
    Vista --> Medico : Muestra alerta: "Ingrese un DNI válido de 8 dígitos."
else [DNI válido]
    CtrlPac -> EntPac : Busca si el paciente ya está registrado en el sistema
    EntPac -> BD : Consulta al paciente por su DNI
    BD --> EntPac : Resultado de la búsqueda
    EntPac --> CtrlPac : Datos del paciente o indicación de que no existe

    alt [Paciente nuevo]
        CtrlPac -> EntPac : Registra al nuevo paciente y le asigna un código de historial único
        EntPac -> BD : Guarda al nuevo paciente con su código de historial
        BD --> EntPac : Confirmación de registro
        CtrlPac --> Vista : Confirma que el paciente fue registrado con su código de historial
        Vista --> Medico : Muestra: "Paciente nuevo registrado. Código de historial asignado."
    else [Paciente ya registrado]
        CtrlPac --> Vista : Confirma que el paciente fue identificado correctamente
        Vista --> Medico : Muestra: "Paciente identificado correctamente."
    end

    Vista --> Medico : Muestra la sección "Carpeta del análisis"\ncon las carpetas existentes del paciente
end

== Paso 3: Seleccionar Carpeta (Opcional) ==

Medico -> Vista : Selecciona una carpeta existente,\ncrea una nueva o elige "Continuar sin seleccionar carpeta"

alt [Crear nueva carpeta]
    Vista -> CtrlCarpeta : Envía nombre y descripción de la nueva carpeta
    CtrlCarpeta -> BD : Guarda la nueva carpeta asociada al médico y al paciente
    BD --> CtrlCarpeta : Confirmación de creación
    CtrlCarpeta --> Vista : Devuelve la carpeta recién creada
    Vista --> Medico : Muestra la nueva carpeta como seleccionada
end

== Paso 4: Ejecutar el Análisis ==

Medico -> Vista : Presiona "Analizar imagen"
Vista --> Medico : Avanza al paso ② "Procesando" en el indicador de pasos\ncon un indicador visual de espera

Vista -> Control : Envía la imagen y los datos del paciente y carpeta seleccionada

Control -> CNN : Envía la imagen al modelo de inteligencia artificial\npara su análisis (tiempo límite: 30 segundos)

alt [El modelo responde exitosamente]
    CNN --> Control : Devuelve el diagnóstico: clase principal\ny porcentajes de probabilidad por categoría\n(Retinopatía Diabética, Glaucoma, Catarata, Normal)
    Control --> Vista : Entrega los resultados al navegador
    Vista --> Medico : Avanza al paso ③ "Resultado" y muestra:\n- Alerta en rojo si se detectó anomalía (ej. "Retinopatía Diabética —\n  Alta probabilidad de anomalía detectada")\n- Aviso en amarillo: "Este resultado es referencial.\n  No reemplaza el diagnóstico médico definitivo."\n- Barras de probabilidad por categoría\n- Campo para escribir el diagnóstico del médico\n- Botón "Guardar análisis"

else [Tiempo de espera excedido]
    CNN --> Control : Sin respuesta (tiempo agotado)
    Control --> Vista : Informa el problema de tiempo
    Vista --> Medico : Muestra aviso:\n"El análisis está tardando más de lo esperado.\nVerifique su conexión o intente nuevamente."

else [Error interno en el modelo de IA]
    CNN --> Control : Error en el procesamiento
    Control --> Vista : Informa el error del modelo
    Vista --> Medico : Muestra aviso:\n"No se pudo completar el análisis.\nPor favor intente nuevamente\no contacte al administrador."
end

== Paso 5: Guardar y Descargar Reporte ==

Medico -> Vista : Escribe su diagnóstico clínico (opcional)\ny presiona "Guardar análisis"
Vista -> Control : Envía todos los datos del análisis:\nresultados, diagnóstico médico, paciente y carpeta
Control -> EntAnalisis : Registra el análisis completo en el sistema
EntAnalisis -> BD : Guarda todos los datos del análisis incluyendo\nresultados de IA, datos del paciente, carpeta y diagnóstico médico
BD --> EntAnalisis : Confirmación de guardado exitoso
EntAnalisis --> Control : Confirma el registro con el identificador del análisis
Control --> Vista : Análisis guardado correctamente
Vista --> Medico : Muestra el botón "Descargar reporte PDF" habilitado\ny el botón "Nuevo análisis"

Medico -> Vista : Presiona "Descargar reporte PDF"
Vista --> Medico : Genera y descarga automáticamente el reporte PDF\ncon el diagnóstico, los resultados de IA y los datos del médico

@enduml

' ============================================================
' RF-06: Gestionar Historial por Paciente (CU-06)
' ============================================================
@startuml RF06_SRS_GestionarHistorialPaciente

title RF-06: Gestionar Historial por Paciente [Diagrama de Secuencia SRS]

actor "Médico Oftalmólogo" as Medico
participant "Pantalla: Historial de Pacientes\n(views/medico/pacientes.php):\nVista de Historial" as Vista
participant "Control: Paciente\n(controllers/PacienteController.php):\nGestión de Historial" as Control
participant "Control: Análisis\n(controllers/AnalisisController.php):\nDatos de Análisis para PDF" as CtrlAnalisis
entity "Entidad: Paciente\n(models/PacienteModel.php):\nDatos del Paciente" as EntPac
entity "Entidad: Carpeta\n(models/CarpetaModel.php):\nCarpetas de Análisis" as EntCarpeta
database "Base de Datos (Railway DB)" as BD

box "Proceso de Gestión del Historial" #White
    participant Medico
    participant Vista
    participant Control
    participant CtrlAnalisis
    participant EntPac
    participant EntCarpeta
    participant BD
end box

== Cargar Lista de Pacientes ==

Medico -> Vista : Accede al módulo "Historial de pacientes"\ndesde el menú lateral
Vista -> Control : Solicita la lista de pacientes con análisis registrados\npara el médico en sesión
Control -> EntPac : Obtiene todos los pacientes con análisis del médico
EntPac -> BD : Consulta la lista de pacientes con sus estadísticas:\nDNI, código, número de carpetas, total de análisis,\nalertas activas y fecha del último análisis
BD --> EntPac : Listado de pacientes con sus datos resumidos
EntPac --> Control : Devuelve el listado completo
Control --> Vista : Presenta la lista de pacientes

alt [No hay pacientes con análisis registrados]
    Vista --> Medico : Muestra mensaje:\n"No hay pacientes con análisis registrados."
else [Hay pacientes registrados]
    Vista --> Medico : Muestra las tarjetas de cada paciente con:\nCódigo de paciente, DNI, fecha del último análisis,\ncantidad de carpetas, total de análisis\ny badge de alertas si existen anomalías detectadas
end

== Buscar un Paciente ==

Medico -> Vista : Escribe en la barra de búsqueda\nun DNI o código de paciente para filtrar
Vista -> Vista : Filtra instantáneamente las tarjetas\nde pacientes que coincidan con el texto ingresado
Vista --> Medico : Muestra solo las tarjetas de pacientes\nque coinciden con la búsqueda

== Ver Detalle del Historial ==

Medico -> Vista : Presiona "Ver detalle" en la tarjeta\nde un paciente específico
Vista -> Control : Solicita el detalle completo del historial del paciente\nmediante una petición asíncrona (sin recargar la página)
Control -> EntPac : Obtiene el detalle del paciente:\ncarpetas con sus análisis y análisis sin carpeta
EntPac -> BD : Consulta todas las carpetas del paciente\nasociadas al médico y sus análisis contenidos
BD --> EntPac : Datos de carpetas y análisis
EntPac -> EntCarpeta : Solicita los análisis de cada carpeta\nordenados del más reciente al más antiguo
EntCarpeta -> BD : Consulta análisis por carpeta ordenados cronológicamente
BD --> EntCarpeta : Análisis con fecha, resultado y probabilidad

alt [Error de conexión al cargar el detalle]
    Control --> Vista : Informa que no se pudo obtener el historial
    Vista --> Medico : Muestra: "Error al cargar el detalle."
else [Historial cargado correctamente]
    Control --> Vista : Devuelve el historial completo del paciente
    Vista --> Medico : Despliega debajo de la tarjeta:\n- Carpetas del paciente (con cantidad de análisis por carpeta)\n- Sección "Análisis sin carpeta" (si existen análisis sin asignar)\n- Un campo de búsqueda para filtrar por nombre de carpeta
end

== Explorar una Carpeta ==

Medico -> Vista : Hace clic en una carpeta específica
Vista --> Medico : Expande la carpeta y muestra los análisis\nordedos del más reciente al más antiguo.\nCada análisis muestra:\n- Fecha y hora del análisis\n- Resultado principal (ej. Retinopatía Diabética)\n- Porcentaje de probabilidad\n- Indicador de alerta (Normal o Alerta en rojo)\n- Botón para descargar el reporte PDF

== Descargar Reporte PDF de un Análisis ==

Medico -> Vista : Presiona el botón "PDF" en uno de los análisis del historial
Vista -> CtrlAnalisis : Solicita los datos completos del análisis seleccionado
CtrlAnalisis -> BD : Obtiene todos los datos del análisis:\nresultados de IA, diagnóstico médico, imagen y datos del paciente
BD --> CtrlAnalisis : Datos completos del análisis
CtrlAnalisis --> Vista : Devuelve los datos listos para generar el PDF
Vista --> Medico : Genera y descarga automáticamente el reporte PDF\ncon los datos del análisis, imagen de la retinografía,\nresultados de IA y diagnóstico del médico

@enduml