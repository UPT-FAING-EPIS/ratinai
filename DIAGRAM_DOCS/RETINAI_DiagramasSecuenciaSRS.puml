@startuml RF01_SRS_CrearCuentaOftalmologo

title RF-01: Crear Cuenta de Oftalmólogo

actor "Administrador" as Admin
participant "Vista (views/admin/create_doctor.php):\nGestión de Médicos" as Vista
participant "Control (controllers/DoctorController.php):\nCuenta Médico" as Control
participant "Servicio (services/MailService.php):\nNotificación por Correo" as Mail
entity "Entidad (models/DoctorModel.php):\nMédico" as Entidad
database "Base de Datos (Railway DB)" as BD

box "Proceso de Registro de Médico" #White
    participant Admin
    participant Vista
    participant Control
    participant Mail
    participant Entidad
    participant BD
end box

Admin -> Vista : Accede a la sección "Médicos"\ny hace clic en "Agregar Médico"
Vista -> Admin : Muestra formulario con campos:\nNombre, Correo, CMP, Especialidad\ny Contraseña temporal
Admin -> Vista : Completa los campos (agregando especialidad\nnueva si requiere) y presiona "Guardar médico"
Vista -> Control : Envía los datos ingresados
Control -> Control : Valida campos obligatorios, formato de\ncorreo y longitud de contraseña (mínimo 6)

alt [Datos incompletos o inválidos]
    Control --> Vista : Informa qué campos tienen error
    Vista -> Admin : Muestra alertas indicando\nlos errores a corregir en el formulario
else [Datos válidos]
    Control -> BD : Verifica que el CMP y el correo\nno estén registrados previamente
    BD --> Control : Resultado de la verificación

    alt [CMP o correo ya registrado]
        Control --> Vista : Informa duplicidad de datos
        Vista -> Admin : Muestra alerta indicando que\nel CMP o correo ya existe en el sistema
    else [Datos disponibles]
        alt [Seleccionó agregar "Nueva Especialidad"]
            Control -> BD : Guarda la nueva especialidad\nen el catálogo del sistema
        end

        Control -> Entidad : Crea la cuenta del médico con estado\n"Activo" y la contraseña temporal cifrada
        Entidad -> BD : Guarda los datos del médico\nasociados al hospital del Administrador
        BD --> Entidad : Confirmación de guardado
        Entidad --> Control : Retorna confirmación

        Control -> Mail : Solicita enviar correo de bienvenida\ncon la contraseña temporal asignada
        
        alt [Correo enviado exitosamente]
            Mail --> Control : Confirma envío
            Control --> Vista : Confirma creación exitosa
            Vista -> Admin : Redirige a la lista de médicos y muestra:\n"Cuenta creada. Contraseña enviada al correo."
        else [Fallo en el servicio de correo]
            Mail --> Control : Informa fallo en envío
            Control --> Vista : Informa creación exitosa pero fallo de correo
            Vista -> Admin : Muestra cuadro azul de advertencia con la\ncontraseña temporal para entrega manual.
        end
    end
end

@enduml

@startuml RF03_SRS_GestionarMedicos

title RF-03: Gestionar Médicos Activos del Establecimiento

actor "Administrador" as Admin
participant "Vista (views/admin/doctor.php):\nGestión de Médicos" as Vista
participant "Pop-up (views/admin/modal_edit.php):\nEditar Médico" as ModalEdit
participant "Pop-up (views/admin/modal_reset.php):\nResetear Contraseña" as ModalReset
participant "Control (controllers/DoctorController.php):\nCuenta Médico" as Control
participant "Serv. Util (utils/PasswordHelper.php):\nGenerador Contraseñas" as Util
participant "Servicio (services/MailService.php):\nNotificación por Correo" as Mail
entity "Entidad (models/DoctorModel.php):\nMédico" as Entidad
database "Base de Datos (Railway DB)" as BD

box "Proceso de Gestión de Médicos" #White
    participant Admin
    participant Vista
    participant ModalEdit
    participant ModalReset
    participant Control
    participant Util
    participant Mail
    participant Entidad
    participant BD
end box

Admin -> Vista : Selecciona opción "Médicos"
Vista -> Admin : Muestra lista de médicos activos
Admin -> Vista : Elige acción (Editar, Resetear Contraseña o Desactivar)

alt [Editar Médico]
    Admin -> Vista : Clic en "Editar"
    Vista -> ModalEdit : Abre Pop-up de Edición
    ModalEdit -> Admin : Muestra formulario con datos actuales
    Admin -> ModalEdit : Modifica datos y guarda
    ModalEdit -> Control : Envía nuevos datos editados
    Control -> BD : Verifica que correo y CMP no estén duplicados
    
    alt [Duplicidad]
        BD --> Control : Duplicados encontrados
        Control --> ModalEdit : Informa error de duplicidad
        ModalEdit -> Admin : Muestra alerta en el formulario
    else [Datos disponibles]
        BD --> Control : Disponibles
        Control -> Entidad : Actualiza información del médico
        Entidad -> BD : Guarda los cambios (nombre, correo, CMP, especialidad)
        BD --> Entidad : Confirmación
        Entidad --> Control : Ok
        Control --> ModalEdit : Confirmación de actualización
        ModalEdit -> Vista : Cierra Pop-up y recarga
        Vista -> Admin : Muestra mensaje de éxito y tabla actualizada
    end

else [Resetear Contraseña]
    Admin -> Vista : Clic en "Resetear contraseña"
    Vista -> ModalReset : Abre Pop-up de Confirmación
    ModalReset -> Admin : Muestra aviso de reseteo
    Admin -> ModalReset : Confirma reseteo
    ModalReset -> Control : Solicita reseteo
    Control -> Util : Genera nueva contraseña temporal
    Util --> Control : Contraseña temporal generada
    Control -> Entidad : Asigna contraseña al médico y cambia estado temporal
    Entidad -> BD : Guarda nueva clave encriptada
    BD --> Entidad : OK
    Entidad --> Control : OK
    
    Control -> Mail : Envía contraseña temporal por correo
    alt [Correo exitoso]
        Mail --> Control : Envío OK
        Control --> ModalReset : Confirmación de reseteo y envío
        ModalReset -> Vista : Cierra Pop-up y recarga
        Vista -> Admin : Muestra mensaje de éxito
    else [Correo fallido]
        Mail --> Control : Fallo
        Control --> ModalReset : Informa fallo al enviar
        ModalReset -> Admin : Muestra mensaje de error sin recargar tabla
    end

else [Desactivar Acceso]
    Admin -> Vista : Clic en "Desactivar" y confirma
    Vista -> Control : Solicita desactivación
    Control -> Entidad : Cambia el estado del médico a inactivo
    Entidad -> BD : Actualiza estado en BD (activo=0)
    BD --> Entidad : Confirmación
    Entidad --> Control : OK
    Control --> Vista : Confirma desactivación
    Vista -> Admin : Muestra mensaje y retira al médico de la lista
end

@enduml

@startuml RF08_SRS_RegistroCentroOftalmologico

title RF-08: Solicitar Registro de Centro Oftalmológico y Aprobación [Diagrama de Secuencia SRS]

actor "Titular del Centro\nOftalmológico" as Titular
actor "Super Administrador" as SADM
participant "Página Principal\n(index.php)" as Index
participant "Vista: Registro de Centro\n(views/auth/solicitud_registro.php)" as VistaReg
participant "Lógica JS\n(assets/js/auth/solicitud_registro.js)" as JS
participant "Vista: Solicitudes\n(views/superadmin/SolicitudesRegistro.php)" as VistaSAD
participant "Control: Solicitud\n(controllers/SolicitudController.php)" as Control
participant "Servicio: Correo\n(services/MailService.php)" as Mail
database "Base de Datos (Railway DB)" as BD

box "Fase 1: Solicitud de Registro" #White
    participant Titular
    participant Index
    participant VistaReg
    participant JS
    participant Control
    participant Mail
    participant BD
end box

Titular -> Index : Visita la página principal
Index --> Titular : Muestra botón "Registrar centro oftalmológico"
Titular -> Index : Clic en "Registrar centro oftalmológico"\n(enlace a views/auth/solicitud_registro.php)
Index -> VistaReg : HTTP GET views/auth/solicitud_registro.php
VistaReg --> Titular : Muestra formulario de registro\n(Datos del centro, titular, correo, evidencias)

Titular -> JS : Llena correo y hace clic en "Enviar código"
JS -> Control : fetch POST action=send_code\n{correo, nombres}
Control -> Mail : Solicita envío de código de verificación (6 dígitos)
Mail --> Control : Código enviado al correo del titular
Control --> JS : {success: true}
JS --> VistaReg : Habilita campo de código + muestra countdown

Titular -> VistaReg : Ingresa código recibido en el correo
Titular -> VistaReg : Adjunta evidencias del establecimiento (JPG/PNG/PDF)
JS -> JS : Convierte archivos a Base64 y rellena campos ocultos
Titular -> VistaReg : Clic en "Enviar solicitud"
JS -> JS : Valida todos los campos del formulario en el cliente
VistaReg -> Control : HTTP POST action=solicitar\n(todos los datos + evidencias en Base64)

Control -> Control : Valida código OTP, datos y evidencias en el servidor
Control -> BD : Verifica que RUC no esté duplicado

alt RUC ya registrado o solicitud en proceso
    BD --> Control : Duplicado encontrado
    Control --> VistaReg : Redirige con mensaje de error
    VistaReg -> Titular : Muestra alerta de duplicidad de RUC
else Datos válidos y RUC disponible
    BD --> Control : OK
    Control -> BD : Guarda solicitud en estado 'pendiente'
    BD --> Control : Confirmación
    Control --> VistaReg : Redirige con mensaje de éxito
    VistaReg -> Titular : Muestra pantalla "¡Solicitud enviada!"\ny enlace para volver al inicio
end

box "Fase 2: Aprobación del Super Administrador" #f8fafc
    participant SADM
    participant VistaSAD
    participant Control
    participant Mail
    participant BD
end box

SADM -> VistaSAD : Accede a "Solicitudes de Registro"
VistaSAD -> BD : Consulta todas las solicitudes (orden: pendientes primero)
BD --> VistaSAD : Lista de solicitudes con sus datos y evidencias
VistaSAD --> SADM : Muestra tabla con botones [✓ Aprobar] [✗ Rechazar]
SADM -> VistaSAD : Revisa evidencias (previsualización en modal)\ny da clic en "✓ Aprobar"
VistaSAD -> Control : HTTP POST action=aprobar {id}

Control -> BD : Crea el establecimiento en la tabla principal
Control -> BD : Crea cuenta de Administrador ('ADM') para el titular\n(con contraseña temporal generada)
Control -> BD : Actualiza solicitud a estado 'aprobado'

Control -> Mail : Envía correo "¡Su solicitud fue aprobada!" al titular
Control -> Mail : Envía correo con contraseña temporal al titular
Mail --> Control : Correos enviados

Control --> VistaSAD : Redirige con mensaje de éxito
VistaSAD -> SADM : Muestra alerta verde "Solicitud aprobada\ny credenciales enviadas al titular"

@enduml