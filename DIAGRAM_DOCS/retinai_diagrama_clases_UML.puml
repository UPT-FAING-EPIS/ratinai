@startuml RetinAI_DiagramaClases_UML

skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #EEEDFE
skinparam classHeaderBackgroundColor #534AB7
skinparam classFontColor #FFFFFF
skinparam classFontSize 13
skinparam classAttributeFontSize 12
skinparam classAttributeIconSize 0
skinparam classBorderColor #534AB7
skinparam ArrowColor #3C3489
skinparam ArrowThickness 1.2
skinparam roundcorner 6
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 60

' ============================================================
' MODELOS (Entidades de dominio)
' ============================================================

class AuthModel {
  -db
  --
  +__construct()
  +getUserByEmail(email : string)
  +updateLastAccess(id : int)
  +updatePassword(id : int, hashedPassword : string)
}

class DoctorModel {
  -db
  --
  +__construct()
  +existsByEmail(correo : string, exclude_id : int = null)
  +existsByCMP(cmp : string, exclude_id : int = null)
  +addSpecialty(descripcion : string)
  +create(data : array)
  +deactivate(id : int, est_id : int)
  +findById(id : int, est_id : int)
  +updateDoctor(id : int, est_id : int, data : array)
  +resetPassword(id : int, est_id : int, hash : string)
}

class Doctor {
  -id : INT
  -nombre : VARCHAR(100)
  -email : VARCHAR(150)
  -cmp : VARCHAR(20)
  -especialidad : VARCHAR(100)
  -institucion : VARCHAR(150)
  -password : VARCHAR(255)
  -isTempPass : BOOL
  -estado : VARCHAR(20)
  -establishmentId : INT
  -createdAt : DATETIME
  --
  +create(data : array) : INT
  +findByEmail(email : string) : Doctor
  +findById(id : int) : Doctor
  +existsByCMP(cmp : string) : BOOL
  +existsByEmail(email : string) : BOOL
  +findActiveByEstablishment(id : int) : List
  +update(id : int, data : array) : BOOL
}

class Admin {
  -id : INT
  -nombre : VARCHAR(100)
  -email : VARCHAR(150)
  -password : VARCHAR(255)
  -isTempPass : BOOL
  -rol : VARCHAR(30)
  -estado : VARCHAR(20)
  -establishmentId : INT
  -createdAt : DATETIME
  --
  +create(data : array) : INT
  +findByEmail(email : string) : Admin
}

class Establishment {
  -id : INT
  -nombre : VARCHAR(150)
  -direccion : VARCHAR(255)
  -tipo : VARCHAR(100)
  -estado : VARCHAR(20)
  -createdAt : DATETIME
  --
  +create(data : array) : INT
  +findById(id : int) : Establishment
}

class Patient {
  -id : INT
  -dni : CHAR(8)
  -historyCode : VARCHAR(10)
  -createdAt : DATETIME
  --
  +create(data : array) : INT
  +findByDni(dni : string) : Patient
  +findByHistoryCode(code : string) : Patient
}

class Analysis {
  -id : INT
  -doctorId : INT
  -patientHistoryId : INT
  -predictedClass : VARCHAR(100)
  -probNormal : DECIMAL(5,4)
  -probRetinopatia : DECIMAL(5,4)
  -probGlaucoma : DECIMAL(5,4)
  -probCatarata : DECIMAL(5,4)
  -imagePath : VARCHAR(500)
  -createdAt : DATETIME
  --
  +create(data : array) : INT
  +findByPatient(patientId : int) : List
  +findById(id : int) : Analysis
}

class ModelConfig {
  -id : INT
  -accuracy : DECIMAL(5,4)
  -sensitivity : DECIMAL(5,4)
  -specificity : DECIMAL(5,4)
  -dataset : VARCHAR(100)
  -modelVersion : VARCHAR(50)
  -limitations : TEXT
  -disclaimer : TEXT
  -active : BOOL
  --
  +getActive() : ModelConfig
}

' ============================================================
' CONTROLADORES
' ============================================================

class DoctorController {
  -model
  --
  +__construct()
  -baseUrl() : string
  -redirect(path : string)
  +createDoctor(nombre : string, correo : string, cmp : string, especialidad : string, esp_nueva : string, password_override : string)
  +deactivate(target_id : int)
  +editDoctor(edit_id : int, nombre : string, correo : string, cmp : string, especialidad : string)
  +resetPassword(reset_id : int)
}

class AuthController {
  -model
  --
  +__construct()
  -baseUrl() : string
  +login(email : string, password : string)
  +changePassword(nueva_password : string, confirma_password : string)
  +logout()
  -redirect(path : string) : void
  -redirectWithError(error : string) : void
  -redirectByRole(rol : string) : void
}

class EstablishmentController {
  +create(nombre : string, direccion : string, tipo : string, adminNombre : string, adminEmail : string) : array
}

class AnalysisController {
  +upload(file : array, doctorId : int) : array
  +process(tmpPath : string, doctorId : int, patientHistoryId : int) : array
  +downloadReport(analysisId : int) : void
  +enableNewAnalysis() : array
}

class PatientController {
  +identifyByDni(dni : string) : array
  +getHistory(historyCode : string) : array
  +recoverHistoryCode(dni : string) : array
}

class ModelInfoController {
  +show() : array
}

' ============================================================
' SERVICIOS
' ============================================================

class MailService {
  +sendTempPassword(email : string, nombre : string, tempPass : string) : BOOL
}

class SessionService {
  -sessionLifetime : INT = 3600
  +start(doctorId : int, nombre : string) : void
  +destroy() : void
  +isActive() : BOOL
}

class ImageValidator {
  -allowedMimes : array
  -maxSizeBytes : INT = 10485760
  +validate(tmpName : string, mime : string, size : int) : array
}

class PdfReportService {
  +generate(reportData : array) : binary
}

class FlaskAPI {
  -baseUrl : STRING
  -timeout : INT = 10
  +predict(imageData : binary) : array
}

' ============================================================
' RELACIONES — Dominio (asociaciones)
' ============================================================

Establishment "1" --> "0..*" Doctor      : registra >
Establishment "1" --> "1..*" Admin       : administra >
Doctor        "1" --> "0..*" Analysis    : realiza >
Patient       "1" --> "0..*" Analysis    : genera >

' ============================================================
' RELACIONES — Controladores → Modelos (dependencias)
' ============================================================

DoctorController        ..> DoctorModel   : <<usa>>
DoctorController        ..> MailService   : <<usa>>
AuthController          ..> AuthModel     : <<usa>>
EstablishmentController ..> Establishment : <<usa>>
EstablishmentController ..> Admin         : <<usa>>
EstablishmentController ..> MailService   : <<usa>>
AnalysisController      ..> Analysis      : <<usa>>
AnalysisController      ..> ImageValidator: <<usa>>
AnalysisController      ..> PdfReportService : <<usa>>
AnalysisController      ..> FlaskAPI      : <<invoca>>
PatientController       ..> Patient       : <<usa>>
PatientController       ..> Analysis      : <<usa>>
ModelInfoController     ..> ModelConfig   : <<usa>>

@enduml
