' ============================================================
' RETINAI — Diagramas de Actividades con Objetos
' Nivel de Análisis (Vista, Control, Entidad)
' Todos los Requerimientos Funcionales RF-01 al RF-15
' ============================================================


' ============================================================
' RF-01: Registrar Usuario Médico
' ============================================================
@startuml RF01_Actividades_RegistrarMedico
title RF-01: Registrar Usuario Médico

skinparam backgroundColor #FFFFFF
skinparam ActivityBackgroundColor #FFFFFF
skinparam ActivityBorderColor #000000
skinparam ActivityArrowColor #000000
skinparam ActivityDiamondBackgroundColor #FFFFFF
skinparam ActivityDiamondBorderColor #000000
skinparam swimlaneBackgroundColor #FAFAFA
skinparam roundcorner 5

|Médico Oftalmólogo|
start
:Accede al formulario de registro;

|Control: Usuario|
:Recibe datos del formulario;
:Valida campos obligatorios y formato de correo;

note right
  **Objeto: DatosFormulario**
  - nombre
  - correo
  - CMP
  - especialidad
  - institución
end note

if (¿Datos completos y válidos?) then (No)
  :Genera mensaje de error de validación;

  |Médico Oftalmólogo|
  :Visualiza campos con error y corrige;
  stop
else (Sí)
  |Control: Usuario|
  :Verifica unicidad del CMP en el sistema;

  note right
    **Objeto: ConsultaCMP**
    - numeroCMP
  end note

  if (¿CMP ya registrado?) then (Sí)
    :Genera mensaje "CMP ya registrado";

    |Médico Oftalmólogo|
    :Visualiza mensaje de duplicado;
    stop
  else (No)
    |Entidad: Usuario|
    :Crea registro de usuario con estado "Pendiente";

    note right
      **Objeto: Usuario**
      - id
      - nombre
      - correo
      - CMP
      - especialidad
      - institución
      - estado = "Pendiente"
    end note

    |Base de Datos|
    :Persiste datos del médico;
    :Retorna confirmación de guardado;

    |Entidad: Usuario|
    :Retorna confirmación a Control;

    |Control: Usuario|
    :Confirma solicitud enviada a Vista;

    |Vista: Registro de Usuario|
    :Muestra "Registro enviado.\nEspere aprobación del administrador";

    |Médico Oftalmólogo|
    :Visualiza confirmación de registro enviado;
    stop
  end if
end if

@enduml


' ============================================================
' RF-02: Iniciar Sesión
' ============================================================
@startuml RF02_Actividades_IniciarSesion
title RF-02: Iniciar Sesión

skinparam backgroundColor #FFFFFF
skinparam ActivityBackgroundColor #FFFFFF
skinparam ActivityBorderColor #000000
skinparam ActivityArrowColor #000000
skinparam ActivityDiamondBackgroundColor #FFFFFF
skinparam ActivityDiamondBorderColor #000000
skinparam swimlaneBackgroundColor #FAFAFA
skinparam roundcorner 5

|Médico Oftalmólogo|
start
:Ingresa correo y contraseña en formulario;

|Control: Autenticación|
:Recibe credenciales desde Vista;

note right
  **Objeto: Credenciales**
  - correo
  - contraseña
end note

|Entidad: Usuario|
:Consulta usuario por correo en BD;

|Base de Datos|
:Ejecuta búsqueda de usuario;
:Retorna datos del usuario o vacío;

|Entidad: Usuario|
:Retorna resultado a Control;

|Control: Autenticación|
if (¿Usuario encontrado?) then (No)
  :Genera mensaje "Credenciales incorrectas";

  |Vista: Inicio de Sesión|
  :Muestra error al médico;

  |Médico Oftalmólogo|
  :Visualiza mensaje de error;
  stop
else (Sí)
  :Verifica contraseña ingresada contra hash almacenado;

  if (¿Contraseña correcta?) then (No)
    :Genera mensaje "Credenciales incorrectas";

    |Vista: Inicio de Sesión|
    :Muestra error al médico;

    |Médico Oftalmólogo|
    :Visualiza mensaje de error;
    stop
  else (Sí)
    :Verifica estado de la cuenta;

    if (¿Cuenta activa?) then (No)
      :Genera mensaje "Cuenta no aprobada aún";

      |Vista: Inicio de Sesión|
      :Muestra "Su cuenta aún no ha sido aprobada";

      |Médico Oftalmólogo|
      :Visualiza mensaje de estado de cuenta;
      stop
    else (Sí)
      :Registra inicio de sesión;
      :Genera token de sesión con expiración 60 min;

      note right
        **Objeto: SesionToken**
        - token
        - usuarioId
        - expiracion = now + 60 min
      end note

      |Entidad: Usuario|
      :Guarda token en BD;

      |Base de Datos|
      :Persiste token de sesión;
      :Retorna confirmación;

      |Control: Autenticación|
      :Autoriza acceso al sistema;

      |Vista: Inicio de Sesión|
      :Redirige al panel principal;

      |Médico Oftalmólogo|
      :Accede al panel principal;
      stop
    end if
  end if
end if

@enduml


' ============================================================
' RF-03: Aprobar o Rechazar Registro de Médico
' ============================================================
@startuml RF03_Actividades_AprobarRechazarRegistro
title RF-03: Aprobar o Rechazar Registro de Médico

skinparam backgroundColor #FFFFFF
skinparam ActivityBackgroundColor #FFFFFF
skinparam ActivityBorderColor #000000
skinparam ActivityArrowColor #000000
skinparam ActivityDiamondBackgroundColor #FFFFFF
skinparam ActivityDiamondBorderColor #000000
skinparam swimlaneBackgroundColor #FAFAFA
skinparam roundcorner 5

|Admin del Establecimiento|
start
:Accede al panel de solicitudes pendientes;

|Control: Usuario|
:Solicita listado de registros con estado "Pendiente";

|Entidad: Usuario|
:Consulta usuarios con estado "Pendiente" del establecimiento;

note right
  **Objeto: FiltroConsulta**
  - estado = "Pendiente"
  - establecimientoId
end note

|Base de Datos|
:Ejecuta consulta filtrada;
:Retorna listado de solicitudes;

|Entidad: Usuario|
:Retorna datos a Control;

|Control: Usuario|
:Envía listado a Vista;

|Vista: Panel de Solicitudes|
:Presenta listado con datos del médico y CMP;

|Admin del Establecimiento|
:Revisa datos del médico (nombre, CMP, especialidad);
:Selecciona solicitud y elige Aprobar o Rechazar;

note right
  **Objeto: DecisionAdmin**
  - usuarioId
  - decision = "Aprobar" | "Rechazar"
end note

|Control: Usuario|
:Recibe decisión del Admin;

if (¿Decisión tomada?) then (Aprobar)
  |Entidad: Usuario|
  :Actualiza estado del usuario a "Activo";

  note right
    **Objeto: Usuario**
    - id
    - estado = "Activo"
  end note

  |Base de Datos|
  :Persiste cambio de estado;
  :Retorna confirmación;

  |Control: Usuario|
  :Confirma aprobación;

  |Vista: Panel de Solicitudes|
  :Muestra "Médico aprobado exitosamente";

  |Admin del Establecimiento|
  :Visualiza confirmación de aprobación;
  stop

else (Rechazar)
  |Entidad: Usuario|
  :Actualiza estado del usuario a "Rechazado";

  note right
    **Objeto: Usuario**
    - id
    - estado = "Rechazado"
  end note

  |Base de Datos|
  :Persiste cambio de estado;
  :Retorna confirmación;

  |Control: Usuario|
  :Confirma rechazo;

  |Vista: Panel de Solicitudes|
  :Muestra "Solicitud rechazada";

  |Admin del Establecimiento|
  :Visualiza confirmación de rechazo;
  stop

end if

@enduml


