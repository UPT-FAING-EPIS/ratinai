skinparam SequenceLifeLineBorderColor #888888

actor "Médico Oftalmólogo" as MED

boundary "Vista:\nPanel Informativo\ndel Modelo" as V
control "Control:\nInformación del Modelo" as C
entity "Entidad:\nConfiguración\ndel Modelo" as E
database "Base de Datos" as BD

== Consulta de Métricas del Modelo ==

MED -> V : Accede a la sección\n"Información del modelo"
V -> C : Solicita datos\ndel modelo CNN
C -> E : Consulta métricas\ny configuración del modelo
E -> BD : Recupera parámetros:\naccuracy, sensibilidad,\nespecificidad, dataset\ny limitaciones conocidas
BD --> E : Retorna datos
E --> C : Retorna métricas\ndel modelo
C --> V : Envía información completa
V --> MED : Presenta panel con:\n- Precisión (accuracy)\n- Sensibilidad\n- Especificidad\n- Dataset: ODIR-5K\n- Limitaciones conocidas\n- Advertencia de uso\n  en contexto clínico

@enduml


