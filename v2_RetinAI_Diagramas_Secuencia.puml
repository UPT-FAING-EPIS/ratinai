' ============================================================
' RETINAI — Diagramas de Secuencia
' Nivel de Análisis (Vista, Control, Entidad)
' Todos los Requerimientos Funcionales RF-01 al RF-15
' ============================================================


' ============================================================
' RF-01: Registrar Usuario Médico
' ============================================================
@startuml RF01_Secuencia_RegistrarMedico
title RF-01: Registrar Usuario Médico

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ArrowColor #000000
skinparam SequenceLifeLineBorderColor #888888

actor "Médico Oftalmólogo" as MED

boundary "Vista:\nRegistro de Usuario" as V
control "Control:\nUsuario" as C
entity "Entidad:\nUsuario" as E
database "Base de Datos" as BD

== Registro de Médico ==

MED -> V : Accede al formulario de registro\ne ingresa nombre, correo,\nCMP, especialidad e institución
V -> C : Envía datos del formulario
C -> C : Valida campos obligatorios\ny formato de correo

alt datos incompletos o inválidos
    C --> V : Informa error de validación
    V --> MED : Muestra campos\ncon error a corregir
else datos válidos
    C -> C : Verifica que el CMP\nno esté registrado previamente
    alt CMP ya registrado
        C --> V : Informa CMP duplicado
        V --> MED : Muestra "El número CMP\nya se encuentra registrado"
    else CMP disponible
        C -> E : Crea registro de usuario\ncon estado "Pendiente de aprobación"
        E -> BD : Guarda datos del médico
        BD --> E : Confirmación
        E --> C : Retorna confirmación de registro
        C --> V : Confirma solicitud enviada
        V --> MED : Muestra "Registro enviado.\nEspere la aprobación\ndel administrador"
    end
end

@enduml


' ============================================================
' RF-02: Iniciar Sesión
' ============================================================
@startuml RF02_Secuencia_IniciarSesion
title RF-02: Iniciar Sesión

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ArrowColor #000000
skinparam SequenceLifeLineBorderColor #888888

actor "Médico Oftalmólogo" as MED

boundary "Vista:\nInicio de Sesión" as V
control "Control:\nAutenticación" as C
entity "Entidad:\nUsuario" as E
database "Base de Datos" as BD

== Autenticación ==

MED -> V : Ingresa correo\ny contraseña
V -> C : Envía credenciales
C -> E : Solicita verificación\nde credenciales
E -> BD : Consulta usuario\npor correo
BD --> E : Retorna datos del usuario

alt usuario no encontrado
    E --> C : Usuario inexistente
    C --> V : Informa error
    V --> MED : Muestra "Credenciales\nincorrectas"
else usuario encontrado
    C -> C : Verifica contraseña
    alt contraseña incorrecta
        C --> V : Informa error
        V --> MED : Muestra "Credenciales\nincorrectas"
    else contraseña correcta
        C -> C : Verifica estado\nde la cuenta
        alt cuenta pendiente o desactivada
            C --> V : Informa estado de cuenta
            V --> MED : Muestra "Su cuenta aún\nno ha sido aprobada\npor el administrador"
        else cuenta activa
            C -> E : Registra inicio de sesión\ny genera token de sesión
            E -> BD : Guarda token con\nexpiración de 60 minutos
            BD --> E : Confirmación
            E --> C : Retorna token de sesión
            C --> V : Autoriza acceso
            V --> MED : Redirige al\npanel principal
        end
    end
end

@enduml


' ============================================================
' RF-03: Aprobar o Rechazar Registro de Médico
' ============================================================
@startuml RF03_Secuencia_AprobarRechazarRegistro
title RF-03: Aprobar o Rechazar Registro de Médico

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ArrowColor #000000
skinparam SequenceLifeLineBorderColor #888888

actor "Admin del\nEstablecimiento" as ADM

boundary "Vista:\nPanel de Solicitudes" as V
control "Control:\nUsuario" as C
entity "Entidad:\nUsuario" as E
database "Base de Datos" as BD

== Revisión de Solicitudes Pendientes ==

ADM -> V : Accede al panel de\nsolicitudes pendientes
V -> C : Solicita listado de\nregistros pendientes
C -> E : Consulta usuarios\ncon estado "Pendiente"
E -> BD : Ejecuta consulta
BD --> E : Retorna listado de solicitudes
E --> C : Retorna datos
C --> V : Muestra solicitudes pendientes
V --> ADM : Presenta listado con\ndatos del médico y CMP

== Decisión del Administrador ==

ADM -> V : Selecciona una solicitud\ny elige Aprobar o Rechazar
V -> C : Envía decisión y\nID del usuario

alt decisión: Aprobar
    C -> E : Actualiza estado\na "Activo"
    E -> BD : Guarda cambio de estado
    BD --> E : Confirmación
    E --> C : Retorna confirmación
    C --> V : Confirma aprobación
    V --> ADM : Muestra "Médico aprobado\nexitosamente"
else decisión: Rechazar
    C -> E : Actualiza estado\na "Rechazado"
    E -> BD : Guarda cambio de estado
    BD --> E : Confirmación
    E --> C : Retorna confirmación
    C --> V : Confirma rechazo
    V --> ADM : Muestra "Solicitud\nrechazada"
end

@enduml


