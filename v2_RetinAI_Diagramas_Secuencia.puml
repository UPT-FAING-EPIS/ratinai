control "Control:\nAnálisis" as C
entity "Entidad:\nAnálisis" as E
database "Base de Datos" as BD

== Presentación de Resultados ==

C -> C : Obtiene vector de\nprobabilidades del modelo CNN:\n- Normal\n- Retinopatía Diabética\n- Glaucoma\n- Catarata
C -> C : Identifica clase\nde mayor probabilidad\ncomo resultado principal
C -> E : Guarda resultado\ncon probabilidades por clase
E -> BD : Persiste resultado\ndel análisis
BD --> E : Confirmación
E --> C : Retorna datos\ndel análisis guardado
C --> V : Envía resultado principal\ny porcentajes por clase
V --> MED : Presenta resultado destacado\ncon indicadores visuales\ny porcentajes de las\ncuatro categorías\njunto a advertencia\nde uso clínico referencial

@enduml


' ============================================================
' RF-10: Activar Alerta Visual ante Anomalía
' ============================================================
@startuml RF10_Secuencia_AlertaVisual
title RF-10: Activar Alerta Visual ante Anomalía

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ArrowColor #000000
skinparam SequenceLifeLineBorderColor #888888

actor "Médico Oftalmólogo" as MED

boundary "Vista:\nResultado de Análisis" as V
control "Control:\nAlertas" as C
entity "Entidad:\nAnálisis" as E
database "Base de Datos" as BD

== Evaluación de Umbral ==

C -> C : Recibe probabilidades\npor clase del modelo CNN
C -> C : Compara probabilidad\nde anomalía detectada\ncontra umbral configurado

alt probabilidad de anomalía >= umbral
    C -> E : Registra alerta\nactivada en el análisis
    E -> BD : Guarda estado\nde alerta
    BD --> E : Confirmación
    E --> C : Retorna confirmación
    C --> V : Envía señal de alerta\ncon clase detectada
    V --> MED : Activa indicador visual\nprominente (color rojo\ne ícono de alerta)\ncon clase de anomalía\ndestacada
else probabilidad < umbral
    C --> V : Envía resultado\nsin alerta
    V --> MED : Muestra resultado\nen estado normal\nsin indicador de alerta
end

@enduml


