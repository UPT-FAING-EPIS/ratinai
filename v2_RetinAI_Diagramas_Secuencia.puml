' ============================================================
' RF-12: Gestionar Historial por Paciente
' ============================================================
@startuml RF12_Secuencia_GestionarHistorial
title RF-12: Gestionar Historial por Paciente

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ArrowColor #000000
skinparam SequenceLifeLineBorderColor #888888

actor "Médico Oftalmólogo" as MED

boundary "Vista:\nAnálisis Retinal" as V
control "Control:\nHistorial" as C
entity "Entidad:\nPaciente" as EP
entity "Entidad:\nAnálisis" as EA
database "Base de Datos" as BD

== Primer Análisis del Paciente ==

MED -> V : Ingresa DNI del paciente\nantes de confirmar análisis
V -> C : Envía DNI del paciente
C -> EP : Verifica si el paciente\nya tiene código de historial
EP -> BD : Consulta paciente\npor DNI
BD --> EP : Retorna resultado

alt paciente nuevo
    EP -> EP : Genera código único\nde historial automáticamente
    EP -> BD : Guarda paciente\ncon código generado
    BD --> EP : Confirmación
    EP --> C : Retorna código\nde historial nuevo
    C --> V : Muestra código generado
    V --> MED : Presenta "Código de historial\nasignado al paciente:\n[CÓDIGO]"
else paciente existente
    EP --> C : Retorna código\nde historial existente
    C --> V : Confirma paciente encontrado
    V --> MED : Muestra "Paciente\nidentificado correctamente"
end

== Consulta de Historial ==

MED -> V : Ingresa código de historial\ny solicita ver historial
V -> C : Solicita historial\ndel paciente
C -> EA : Consulta análisis\nassociados al código
EA -> BD : Ejecuta consulta\nordenada por fecha
BD --> EA : Retorna listado\nde análisis
EA --> C : Retorna historial
C --> V : Envía historial completo
V --> MED : Presenta análisis\nordenados cronológicamente\ncon fecha, resultado\ny opción de ver detalle

@enduml


' ============================================================
' RF-13: Recuperar Código de Historial por DNI
' ============================================================
@startuml RF13_Secuencia_RecuperarCodigoHistorial
title RF-13: Recuperar Código de Historial por DNI

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ArrowColor #000000
skinparam SequenceLifeLineBorderColor #888888

actor "Médico Oftalmólogo" as MED

boundary "Vista:\nRecuperación de\nCódigo de Historial" as V
control "Control:\nHistorial" as C
entity "Entidad:\nPaciente" as E
database "Base de Datos" as BD

== Recuperación de Código ==

MED -> V : Accede a la opción\n"Recuperar código de historial"\ne ingresa DNI del paciente
V -> C : Envía DNI\npara búsqueda
C -> C : Valida formato\ndel DNI ingresado

alt formato de DNI inválido
    C --> V : Informa error de formato
    V --> MED : Muestra "Ingrese un DNI\nválido de 8 dígitos"
else DNI válido
    C -> E : Busca paciente\npor DNI
    E -> BD : Ejecuta consulta
    BD --> E : Retorna resultado

    alt paciente no encontrado
        E --> C : Sin resultados
        C --> V : Informa no encontrado
        V --> MED : Muestra "No se encontró\nningún paciente con\nese número de DNI"
    else paciente encontrado
        E --> C : Retorna código\nde historial
        C --> V : Envía código recuperado
        V --> MED : Muestra "El código de historial\nde este paciente es:\n[CÓDIGO]"
    end
end

@enduml


