' RF-15: Mostrar Advertencia de Uso Clínico
' ============================================================
@startuml RF15_Secuencia_AdvertenciaUsoClinico
title RF-15: Mostrar Advertencia de Uso Clínico

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ArrowColor #000000
skinparam SequenceLifeLineBorderColor #888888

actor "Médico Oftalmólogo" as MED

boundary "Vista:\nResultado de Análisis" as V
control "Control:\nAdvertencias" as C
entity "Entidad:\nConfiguración\ndel Sistema" as E
database "Base de Datos" as BD

== Visualización de Advertencia ==

MED -> V : Accede a la pantalla\nde resultados del análisis
V -> C : Solicita configuración\nde advertencias del sistema
C -> E : Consulta texto\nde advertencia activo
E -> BD : Recupera leyenda\nconfigurada
BD --> E : Retorna texto:\n"Este resultado es de\ncarácter referencial.\nNo reemplaza el\ndiagnóstico médico definitivo."
E --> C : Retorna advertencia
C --> V : Envía advertencia\npara mostrar
V --> MED : Despliega advertencia\nde forma permanente\ny visible en pantalla\nde resultados

note over V, MED
  La advertencia también se incluye
  automáticamente en todos los
  reportes PDF generados (RF-11)
end note

@enduml
