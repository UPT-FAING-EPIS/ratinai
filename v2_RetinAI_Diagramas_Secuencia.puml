' ============================================================
' RF-06: Cargar y Procesar Imagen Retinal
' ============================================================
@startuml RF06_Secuencia_CargarProcesarImagen
title RF-06: Cargar y Procesar Imagen Retinal

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ArrowColor #000000
skinparam SequenceLifeLineBorderColor #888888

actor "Médico Oftalmólogo" as MED

boundary "Vista:\nAnálisis Retinal" as V
control "Control:\nAnálisis" as C
entity "Entidad:\nAnálisis" as E
database "Base de Datos" as BD

== Carga de Imagen ==

MED -> V : Selecciona retinografía\nen formato JPG o PNG
V -> C : Envía imagen\npara procesamiento
C -> C : Valida formato\ny tamaño de imagen

alt formato o tamaño inválido
    C --> V : Informa error de formato
    V --> MED : Muestra "Solo se aceptan\nimágenes JPG o PNG"
else imagen válida
    C -> C : Aplica preprocesamiento:\nredimensionamiento 224x224,\nnormalización y ajuste\nde brillo y contraste

    == Procesamiento CNN ==

    C -> C : Ejecuta inferencia\ncon modelo CNN (TF Lite)

    alt tiempo de respuesta supera 5 segundos
        C --> V : Informa tiempo excedido
        V --> MED : Muestra "El sistema tardó\nmás de lo esperado.\nIntente nuevamente"
    else inferencia exitosa
        C -> E : Crea registro del análisis\ncon imagen y resultados
        E -> BD : Guarda análisis
        BD --> E : Confirmación
        E --> C : Retorna ID del análisis
        C --> V : Envía resultados con\nprobabilidades por clase
        V --> MED : Muestra resultado principal\ny porcentajes de las\ncuatro categorías
    end
end

@enduml


' ============================================================
' RF-07: Validar Imagen Cargada
' ============================================================
@startuml RF07_Secuencia_ValidarImagen
title RF-07: Validar Imagen Cargada

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ArrowColor #000000
skinparam SequenceLifeLineBorderColor #888888

actor "Médico Oftalmólogo" as MED

boundary "Vista:\nAnálisis Retinal" as V
control "Control:\nValidación de Imagen" as C
entity "Entidad:\nAnálisis" as E
database "Base de Datos" as BD

== Validación de Imagen ==

MED -> V : Selecciona imagen\ny confirma carga
V -> C : Envía imagen\npara validación
C -> C : Verifica formato JPG/PNG\ny tamaño máximo de 10 MB

alt formato incorrecto
    C --> V : Rechaza imagen
    V --> MED : Muestra "Formato no válido.\nUse JPG o PNG"
else tamaño excede 10 MB
    C --> V : Rechaza imagen
    V --> MED : Muestra "El archivo supera\nel tamaño máximo\npermitido de 10 MB"
else formato y tamaño válidos
    C -> C : Evalúa calidad\nde la imagen

    alt calidad baja detectada
        C --> V : Informa baja calidad\npero permite continuar
        V --> MED : Muestra advertencia:\n"Imagen de baja calidad.\nEl resultado puede\nno ser óptimo"\ny habilita botón continuar
        MED -> V : Confirma continuar\ncon el análisis
        V -> C : Autoriza procesamiento
    else calidad aceptable
        C --> V : Imagen aprobada
    end

    C -> E : Registra imagen\nvalidada para análisis
    E -> BD : Guarda referencia\nde imagen
    BD --> E : Confirmación
    E --> C : Listo para análisis
    C --> V : Habilita procesamiento CNN
    V --> MED : Muestra "Imagen lista\npara analizar"
end

@enduml


' ============================================================
' RF-08: Solicitar Registro de Centro Oftalmológico
' ============================================================
@startuml RF08_Actividades_RegistroCentroOftalmologico
title RF-08: Solicitar Registro de Centro Oftalmológico

skinparam backgroundColor #FFFFFF
skinparam ActivityBackgroundColor #FFFFFF
skinparam ActivityBorderColor #000000
skinparam ActivityArrowColor #000000
skinparam ActivityDiamondBackgroundColor #FFFFFF
skinparam ActivityDiamondBorderColor #000000
skinparam swimlaneBackgroundColor #FAFAFA
skinparam roundcorner 5

|Dueño del Centro Oftalmológico|
start
:Accede a la página web de RetinAI;

note right
  **Objeto: SesiónWeb**
  - origen = web pública
  - autenticado = false
end note

:Selecciona la opción\n"Registrar mi centro oftalmológico";

|Vista: Formulario de Registro|
:Muestra formulario de solicitud\ncon los campos requeridos;

note right
  **Objeto: FormularioRegistro**
  - nombre_centro : String
  - direccion : String
  - tipo : Enum {público, privado}
  - ruc : String
  - estado = "vacío"
end note

|Dueño del Centro Oftalmológico|
:Completa los datos del formulario\n(nombre, dirección, tipo y RUC);

note right
  **Objeto: FormularioCompletado**
  - nombre_centro = ingresado
  - direccion = ingresada
  - tipo = seleccionado
  - ruc = ingresado
end note

:Envía el formulario haciendo clic\nen "Enviar solicitud";

|Control: Validación de Solicitud|
:Recibe los datos del formulario;

:Verifica que todos los campos\nobligatorios estén completos;

if (¿Campos completos?) then (No)
  |Vista: Formulario de Registro|
  :Resalta campos faltantes\ny muestra mensaje de error;
  note right
    **Objeto: MensajeError**
    - tipo = "campos_incompletos"
    - mensaje = "Complete todos los\ncampos requeridos"
  end note
  |Dueño del Centro Oftalmológico|
  :Corrige los campos faltantes;
  detach
else (Sí)
  :Verifica el formato del RUC\n(11 dígitos numéricos);
  if (¿RUC válido?) then (No)
    |Vista: Formulario de Registro|
    :Muestra mensaje de RUC inválido;
    note right
      **Objeto: MensajeError**
      - tipo = "ruc_invalido"
      - mensaje = "El RUC no tiene el\nformato correcto"
    end note
    |Dueño del Centro Oftalmológico|
    :Corrige el RUC ingresado;
    detach
  else (Sí)
    :Verifica que el RUC no\nesté ya registrado en el sistema;
    if (¿RUC ya existe?) then (Sí)
      |Vista: Formulario de Registro|
      :Muestra mensaje de RUC\nduplucado;
      note right
        **Objeto: MensajeError**
        - tipo = "ruc_duplicado"
        - mensaje = "Ya existe un centro\ncon este RUC"
      end note
      detach
    else (No)
    endif
  endif
endif

|Entidad: Establecimiento|
:Crea un nuevo registro de\nestablecimiento con estado "Pendiente";

note right
  **Objeto: SolicitudEstablecimiento**
  - id = UUID generado
  - nombre_sede = datos del formulario
  - direccion = datos del formulario
  - tipo = FK a maestro (público/privado)
  - estado = FK a maestro (Pendiente)
  - ruc = ingresado
end note

|Base de Datos|
:Persiste la solicitud de registro\ncon estado "Pendiente";
:Retorna confirmación de guardado;

|Entidad: Establecimiento|
:Confirma creación de la solicitud;

|Vista: Formulario de Registro|
:Muestra mensaje de éxito al dueño;

note right
  **Objeto: MensajeConfirmación**
  - tipo = "exito"
  - mensaje = "Su solicitud ha sido enviada.\nEl administrador revisará\nsu información"
end note

|Dueño del Centro Oftalmológico|
:Visualiza confirmación de\nenvío exitoso de su solicitud;
stop

@enduml


' ============================================================
' RF-09: Mostrar Resultado con Probabilidades
' ============================================================
@startuml RF09_Secuencia_MostrarResultado
title RF-09: Mostrar Resultado con Probabilidades

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ArrowColor #000000
skinparam SequenceLifeLineBorderColor #888888

