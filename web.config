<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- Redirigir raíz al index.php del proyecto -->
        <rule name="Root redirect" stopProcessing="true">
          <match url="^$" />
          <action type="Redirect" url="index.php" redirectType="Permanent" />
        </rule>

        <!-- Servir archivos y directorios existentes tal cual -->
        <rule name="Serve existing files" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- Servir directorios existentes tal cual -->
        <rule name="Serve existing directories" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" />
          </conditions>
          <action type="None" />
        </rule>
      </rules>
    </rewrite>

    <!-- Página de error personalizada -->
    <httpErrors errorMode="DetailedLocalOnly" />

    <!-- Asegurar que PHP maneje .php -->
    <handlers>
      <remove name="PHP_via_FastCGI" />
      <add name="PHP_via_FastCGI"
           path="*.php"
           verb="GET,HEAD,POST"
           modules="FastCgiModule"
           scriptProcessor="D:\Program Files\PHP\v8.2\php-cgi.exe"
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>

    <!-- Documento predeterminado -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.php" />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- Seguridad: ocultar headers de servidor -->
    <security>
      <requestFiltering removeServerHeader="true" />
    </security>
  </system.webServer>
</configuration>
